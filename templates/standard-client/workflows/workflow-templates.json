{
  "version": "2.0",
  "workflows": [
    {
      "id": "",
      "name": "New Lead Welcome",
      "status": "active",
      "trigger": {
        "type": "contactCreated",
        "filters": {
          "source": "website"
        }
      },
      "triggersV2": [
        {
          "name": "New Lead Welcome",
          "type": "contactCreated",
          "status": "active",
          "config": {
            "source": "website"
          },
          "conditions": [
            {
              "conditions": [
                { "field": "email", "operator": "exists", "fieldType": "string" },
                { "field": "source", "operator": "equals", "value": "website", "fieldType": "string" }
              ],
              "logic": "and"
            }
          ],
          "conditionLogic": "and",
          "timeDelay": 5,
          "timeDelayType": "minutes",
          "dedupWindow": 1440,
          "dedupKey": "contactId"
        }
      ],
      "actions": [
        {
          "type": "sendEmail",
          "templateId": "welcome-email",
          "delay": 0
        },
        {
          "type": "addTag",
          "tagId": "new-lead",
          "delay": 0
        },
        {
          "type": "createTask",
          "title": "Follow up with new lead",
          "assignee": "",
          "dueIn": 1,
          "delay": 60
        }
      ]
    },
    {
      "id": "",
      "name": "Tour Reminder",
      "status": "active",
      "trigger": {
        "type": "appointmentUpcoming",
        "minutesBefore": 60
      },
      "actions": [
        {
          "type": "sendEmail",
          "templateId": "tour-reminder",
          "delay": 0
        },
        {
          "type": "sendSMS",
          "templateId": "tour-reminder-sms",
          "delay": 0
        }
      ]
    },
    {
      "id": "",
      "name": "Post-Tour Follow-up",
      "status": "active",
      "trigger": {
        "type": "appointmentCompleted",
        "appointmentType": "tour"
      },
      "actions": [
        {
          "type": "sendEmail",
          "templateId": "post-tour-followup",
          "delay": 1440
        },
        {
          "type": "createTask",
          "title": "Send proposal to tour attendee",
          "assignee": "",
          "dueIn": 2,
          "delay": 2880
        }
      ]
    },
    {
      "id": "",
      "name": "No Response Follow-up",
      "status": "active",
      "trigger": {
        "type": "contactNoResponse",
        "days": 7
      },
      "actions": [
        {
          "type": "sendEmail",
          "templateId": "follow-up-email",
          "delay": 0
        },
        {
          "type": "createTask",
          "title": "Manual follow-up needed",
          "assignee": "",
          "dueIn": 1,
          "delay": 4320
        }
      ]
    },
    {
      "id": "",
      "name": "Booking Confirmation",
      "status": "active",
      "trigger": {
        "type": "opportunityStageChanged",
        "toStage": "Booked/Won"
      },
      "actions": [
        {
          "type": "sendEmail",
          "templateId": "booking-confirmation",
          "delay": 0
        },
        {
          "type": "addTag",
          "tagId": "booked",
          "delay": 0
        },
        {
          "type": "createTask",
          "title": "Send contract and deposit request",
          "assignee": "",
          "dueIn": 0,
          "delay": 0
        }
      ]
    }
  ]
}
