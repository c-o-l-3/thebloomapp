# GoHighLevel Configuration
GHL_API_KEY=your_pit_token_here
GHL_LOCATION_ID=your_location_id_here

# MJML Configuration (optional - uses local mjml-core if not set)
MJML_API_KEY=
MJML_SERVER_ADDRESS=https://api.mjml.io/v1

# Build Configuration
BUILD_OUTPUT_DIR=./output/compiled-emails
DRY_RUN=false
PUSH_TO_GHL=true

# Logging
LOG_LEVEL=info
