              {
                "id": "text-testimonial2",
                "type": "text",
                "values": {
                  "containerPadding": "0px 40px 15px",
                  "text": "<p style=\"font-size:16px;line-height:1.7;color:#555555;font-family:Poppins,sans-serif;margin:0;font-style:italic;\">\"Our families still talk about how relaxed the whole weekend felt. Everyone was in one place, the coordinators handled everything, and we actually got to be guests at our own wedding. I've recommended Cameron Estate to everyone I know who's getting married.\"</p>",
                  "hideDesktop": false
                }
              },
              {
                "id": "text-testimonial2-attribution",
                "type": "text",
