                  "buttonColors": { "color": "#FFFFFF", "backgroundColor": "#2C3E50", "hoverColor": "#FFFFFF", "hoverBackgroundColor": "#1a2632" },
                  "fontSize": "14px", "fontWeight": "500",
                  "fontFamily": { "label": "Poppins", "value": "Poppins,sans-serif", "url": "https://fonts.googleapis.com/css?family=Poppins:400,500,600" },
                  "padding": "14px 35px", "borderRadius": "4px",
                  "text": "<span>Schedule Your Tour</span>", "textAlign": "left", "hideDesktop": false
                }
              },
              {
                "id": "text-cta-body",
                "type": "text",
                "values": {
                  "containerPadding": "0px 40px 12px",
                  "text": "<p style=\"font-size:16px;line-height:1.7;color:#4A4A4A;font-family:Poppins,sans-serif;margin:0;\">I'd love to share more stories and show you around Cameron Estate. Bring your questions — and your vision. We'll have warm cookies and refreshments ready!</p>",
                  "hideDesktop": false
                }
              },
              {
                "id": "text-cta-cta",
                "type": "text",
                "values": {
                  "containerPadding": "0px 40px 30px",
                  "text": "<p style=\"font-size:16px;line-height:1.7;color:#4A4A4A;font-family:Poppins,sans-serif;margin:0;\">Just reply with dates that work for a tour, or email me anytime with questions.</p>",
                  "hideDesktop": false
                }
              }
