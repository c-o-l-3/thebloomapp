              {
                "id": "text-cta-body",
                "type": "text",
                "values": {
                  "containerPadding": "0px 40px 12px",
                  "text": "<p style=\"font-size:16px;line-height:1.7;color:#4A4A4A;font-family:Poppins,sans-serif;margin:0;\">I'd love to show you around Cameron Estate and answer any questions you have about how we compare to other places you're visiting. We have warm cookies and refreshments ready for you!</p>",
                  "hideDesktop": false
                }
              },
              {
                "id": "text-cta-cta",
                "type": "text",
                "values": {
                  "containerPadding": "0px 40px 30px",
                  "text": "<p style=\"font-size:16px;line-height:1.7;color:#4A4A4A;font-family:Poppins,sans-serif;margin:0;\">Just reply with a few dates that work for a tour, or email me anytime with questions.</p>",
                  "hideDesktop": false
                }
              }
            ],
            "values": {}
