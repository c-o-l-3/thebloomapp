  "id": "6989f33e1cf63d439316bd6a",
  "name": "001 E Day 7 - Pinterest",
  "subject": "",
  "previewText": "",
  "html": "<!--\nSubject: We made you a Pinterest board\nPreview Text: Romantic garden party? Moody autumnal vibes? Black-tie elegance? Yes, yes, and yes...\n-->\n<!doctype html>\n<html lang=\"und\" dir=\"auto\" xmlns=\"http://www.w3.org/1999/xhtml\" xmlns:v=\"urn:schemas-microsoft-com:vml\" xmlns:o=\"urn:schemas-microsoft-com:office:office\">\n  <head>\n    <title></title>\n    <!--[if !mso]><!-->\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n    <!--<![endif]-->\n    <meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n    <style type=\"text/css\">\n      #outlook a { padding:0; }\n      body { margin:0;padding:0;-webkit-text-size-adjust:100%;-ms-text-size-adjust:100%; }\n      table, td { border-collapse:collapse;mso-table-lspace:0pt;mso-table-rspace:0pt; }\n      img { border:0;height:auto;line-height:100%; outline:none;text-decoration:none;-ms-interpolation-mode:bicubic; }\n      p { display:block;margin:13px 0; }\n    </style>\n    <!--[if mso]>\n    <noscript>\n    <xml>\n    <o:OfficeDocumentSettings>\n      <o:AllowPNG/>\n      <o:PixelsPerInch>96</o:PixelsPerInch>\n    </o:OfficeDocumentSettings>\n    </xml>\n    </noscript>\n    <![endif]-->\n    <!--[if lte mso 11]>\n    <style type=\"text/css\">\n      .mj-outlook-group-fix { width:100% !important; }\n    </style>\n    <![endif]-->\n    \n      <!--[if !mso]><!-->\n        <link href=\"https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&display=swap\" rel=\"stylesheet\" type=\"text/css\">\n<link href=\"https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap\" rel=\"stylesheet\" type=\"text/css\">\n        <style type=\"text/css\">\n          @import url(https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&display=swap);\n@import url(https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap);\n        </style>\n      <!--<![endif]-->\n\n    \n    \n    <style type=\"text/css\">\n      @media only screen and (min-width:480px) {\n        .mj-column-per-100 { width:100% !important; max-width: 100%; }\n      }\n    </style>\n    <style media=\"screen and (min-width:480px)\">\n      .moz-text-html .mj-column-per-100 { width:100% !important; max-width: 100%; }\n    </style>\n    \n    \n  \n    \n    <style type=\"text/css\">\n\n    @media only screen and (max-width:479px) {\n      table.mj-full-width-mobile { width: 100% !important; }\n      td.mj-full-width-mobile { width: auto !important; }\n    }\n  \n    </style>\n     \n    <style type=\"text/css\">\n/* Progressive enhancement for email clients with CSS support */\n      .heading-primary {\n        font-family: 'Cormorant Garamond', Georgia, serif !important;\n        color: #2C3E50 !important;\n        font-weight: 500 !important;\n        font-size: 32px !important;\n        line-height: 1.2 !important;\n      }\n      .heading-secondary {\n        font-family: 'Cormorant Garamond', Georgia, serif !important;\n        color: #2C3E50 !important;\n        font-weight: 500 !important;\n        font-size: 24px !important;\n        line-height: 1.3 !important;\n      }\n      .body-text {\n        font-family: 'Poppins', Helvetica, Arial, sans-serif !important;\n        color: #4A4A4A !important;\n        font-size: 16px !important;\n        line-height: 1.6 !important;\n      }\n      .signature-text {\n        font-family: 'Cormorant Garamond', Georgia, serif !important;\n        color: #2C3E50 !important;\n        font-size: 20px !important;\n        font-weight: 500 !important;\n      }\n      .testimonial-quote {\n        font-family: 'Cormorant Garamond', Georgia, serif !important;\n        color: #2C3E50 !important;\n        font-size: 20px !important;\n        font-style: italic !important;\n        line-height: 1.4 !important;\n      }\n      .testimonial-attribution {\n        font-family: 'Poppins', Helvetica, Arial, sans-serif !important;\n        color: #666 !important;\n        font-size: 14px !important;\n        font-weight: 500 !important;\n      }\n      .quote-text {\n        font-family: 'Cormorant Garamond', Georgia, serif !important;\n        color: #2C3E50 !important;\n        font-size: 22px !important;\n        font-style: italic !important;\n        line-height: 1.4 !important;\n      }\n      /* Mobile optimizations */\n      @media only screen and (max-width: 480px) {\n        .heading-primary { font-size: 26px !important; }\n        .heading-secondary { font-size: 21px !important; }\n        .body-text div { font-size: 14px !important; line-height: 1.6 !important; }\n        .testimonial-quote div { font-size: 18px !important; }\n        .quote-text div { font-size: 20px !important; }\n        /* Full-width mobile buttons */\n        .cta-primary table,\n        .cta-secondary table { width: 100% !important; }\n        .cta-primary a,\n        .cta-secondary a { display: block !important; width: 100% !important; }\n        .footer-email a { font-size: 11px !important; }\n        .responsive-link a { font-size: 12px !important; word-break: break-all; }\n      }\n    </style>\n    <!-- Fonts: Cormorant Garamond (headings) and Poppins (body) -->\n<!-- Global Attributes -->\n<!-- Custom Styles -->\n<!-- Preview Text -->\n  <!-- outlook-fixes-applied --></head>\n  <body style=\"word-spacing:normal;background-color:#FAFAFA;\">\n    \n    <div style=\"display:none;font-size:1px;color:#ffffff;line-height:1px;max-height:0px;max-width:0px;opacity:0;overflow:hidden;\">Romantic garden party? Moody autumnal vibes? Black-tie elegance? Yes, yes, and yes...</div>\n  \n    \n      <div\n         aria-roledescription=\"email\" style=\"background-color:#FAFAFA;\" role=\"article\" lang=\"und\" dir=\"auto\"\n      >\n        <!-- Opening Content (above the fold) --><!-- Gallery Section (between opening and body) --><!-- Body Content -->\n      \n      <!--[if mso | IE]><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"\" role=\"presentation\" style=\"width:600px;\" width=\"600\" bgcolor=\"#FDFCFA\" ><tr><td style=\"line-height:0px;font-size:0px;mso-line-height-rule:exactly;\"><![endif]-->\n    \n      \n      <div  style=\"background:#FDFCFA;background-color:#FDFCFA;margin:0px auto;max-width:600px;\">\n        \n        <table\n           align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"background:#FDFCFA;background-color:#FDFCFA;width:100%;\"\n        >\n          <tbody>\n            <tr>\n              <td\n                 style=\"direction:ltr;font-size:0px;padding:40px 40px 20px;text-align:center;\"\n              >\n                <!--[if mso | IE]><table role=\"presentation\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"><tr><td class=\"\" style=\"vertical-align:top;width:520px;\" ><![endif]-->\n            \n      <div\n         class=\"mj-column-per-100 mj-outlook-group-fix\" style=\"font-size:0px;text-align:left;direction:ltr;display:inline-block;vertical-align:top;width:100%;\"\n      >\n        \n      <table\n         border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"vertical-align:top;\" width=\"100%\"\n      >\n        <tbody>\n          \n              <tr>\n                <td\n                   align=\"left\" style=\"font-size:0px;padding:0 0 25px;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Cormorant Garamond, Georgia, serif;font-size:28px;font-weight:500;line-height:1.6;text-align:left;color:#2C3E50;\"\n      >{{contact.first_name}},</div>\n    \n                </td>\n              </tr>\n            \n              <tr>\n                <td\n                   align=\"left\" class=\"body-text\" style=\"font-size:0px;padding:0 0 15px;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Poppins, Helvetica, Arial, sans-serif;font-size:16px;line-height:1.7;text-align:left;color:#4A4A4A;\"\n      >Quick question for you: What does your dream wedding actually look like?</div>\n    \n                </td>\n              </tr>\n            \n              <tr>\n                <td\n                   align=\"left\" class=\"body-text\" style=\"font-size:0px;padding:0 0 15px;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Poppins, Helvetica, Arial, sans-serif;font-size:16px;line-height:1.7;text-align:left;color:#4A4A4A;\"\n      >When you think about your wedding day — not what you're \"supposed to\" want, but what you actually envision — what do you see?</div>\n    \n                </td>\n              </tr>\n            \n        </tbody>\n      </table>\n    \n      </div>\n    \n          <!--[if mso | IE]></td></tr></table><![endif]-->\n              </td>\n            </tr>\n          </tbody>\n        </table>\n        \n      </div>\n    \n      \n      <!--[if mso | IE]></td></tr></table><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"\" role=\"presentation\" style=\"width:600px;\" width=\"600\" bgcolor=\"#FFFFFF\" ><tr><td style=\"line-height:0px;font-size:0px;mso-line-height-rule:exactly;\"><![endif]-->\n    \n      \n      <div  style=\"background:#FFFFFF;background-color:#FFFFFF;margin:0px auto;max-width:600px;\">\n        \n        <table\n           align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"background:#FFFFFF;background-color:#FFFFFF;width:100%;\"\n        >\n          <tbody>\n            <tr>\n              <td\n                 style=\"direction:ltr;font-size:0px;padding:30px 40px;text-align:center;\"\n              >\n                <!--[if mso | IE]><table role=\"presentation\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"><tr><td class=\"\" style=\"vertical-align:top;width:520px;\" ><![endif]-->\n            \n      <div\n         class=\"mj-column-per-100 mj-outlook-group-fix\" style=\"font-size:0px;text-align:left;direction:ltr;display:inline-block;vertical-align:top;width:100%;\"\n      >\n        \n      <table\n         border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"vertical-align:top;\" width=\"100%\"\n      >\n        <tbody>\n          \n              <tr>\n                <td\n                   align=\"left\" class=\"body-text\" style=\"font-size:0px;padding:8px 0;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Poppins, Helvetica, Arial, sans-serif;font-size:16px;line-height:1.7;text-align:left;color:#4A4A4A;\"\n      ><strong>Soft and romantic</strong> with lots of candlelight, fresh flowers everywhere, an intimate gathering of your closest people?</div>\n    \n                </td>\n              </tr>\n            \n              <tr>\n                <td\n                   align=\"left\" class=\"body-text\" style=\"font-size:0px;padding:8px 0;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Poppins, Helvetica, Arial, sans-serif;font-size:16px;line-height:1.7;text-align:left;color:#4A4A4A;\"\n      ><strong>Bold and dramatic</strong> with rich, moody colors, a dramatic black-tie affair, making a statement with every detail?</div>\n    \n                </td>\n              </tr>\n            \n              <tr>\n                <td\n                   align=\"left\" class=\"body-text\" style=\"font-size:0px;padding:8px 0;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Poppins, Helvetica, Arial, sans-serif;font-size:16px;line-height:1.7;text-align:left;color:#4A4A4A;\"\n      ><strong>Classic elegance</strong> — timeless, sophisticated, the kind of wedding that could have been in any era and still looks perfect?</div>\n    \n                </td>\n              </tr>\n            \n              <tr>\n                <td\n                   align=\"left\" class=\"body-text\" style=\"font-size:0px;padding:8px 0;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Poppins, Helvetica, Arial, sans-serif;font-size:16px;line-height:1.7;text-align:left;color:#4A4A4A;\"\n      ><strong>A boho garden party</strong> — relaxed, organic, nature-inspired, completely you?</div>\n    \n                </td>\n              </tr>\n            \n              <tr>\n                <td\n                   align=\"left\" class=\"body-text\" style=\"font-size:0px;padding:8px 0;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Poppins, Helvetica, Arial, sans-serif;font-size:16px;line-height:1.7;text-align:left;color:#4A4A4A;\"\n      ><strong>Something totally unexpected</strong> that perfectly captures you two as a couple, whatever that looks like?</div>\n    \n                </td>\n              </tr>\n            \n        </tbody>\n      </table>\n    \n      </div>\n    \n          <!--[if mso | IE]></td></tr></table><![endif]-->\n              </td>\n            </tr>\n          </tbody>\n        </table>\n        \n      </div>\n    \n      \n      <!--[if mso | IE]></td></tr></table><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"\" role=\"presentation\" style=\"width:600px;\" width=\"600\" bgcolor=\"#F5F1EB\" ><tr><td style=\"line-height:0px;font-size:0px;mso-line-height-rule:exactly;\"><![endif]-->\n    \n      \n      <div  style=\"background:#F5F1EB;background-color:#F5F1EB;margin:0px auto;max-width:600px;\">\n        \n        <table\n           align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"background:#F5F1EB;background-color:#F5F1EB;width:100%;\"\n        >\n          <tbody>\n            <tr>\n              <td\n                 style=\"direction:ltr;font-size:0px;padding:35px 40px;text-align:center;\"\n              >\n                <!--[if mso | IE]><table role=\"presentation\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"><tr><td class=\"\" style=\"vertical-align:top;width:520px;\" ><![endif]-->\n            \n      <div\n         class=\"mj-column-per-100 mj-outlook-group-fix\" style=\"font-size:0px;text-align:left;direction:ltr;display:inline-block;vertical-align:top;width:100%;\"\n      >\n        \n      <table\n         border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"vertical-align:top;\" width=\"100%\"\n      >\n        <tbody>\n          \n              <tr>\n                <td\n                   align=\"left\" style=\"font-size:0px;padding:0 0 15px;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Cormorant Garamond, Georgia, serif;font-size:24px;font-weight:500;line-height:1.6;text-align:left;color:#2C3E50;\"\n      >Here's the Thing About Cameron Estate...</div>\n    \n                </td>\n              </tr>\n            \n              <tr>\n                <td\n                   align=\"left\" class=\"body-text\" style=\"font-size:0px;padding:0 0 15px;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Poppins, Helvetica, Arial, sans-serif;font-size:16px;line-height:1.7;text-align:left;color:#4A4A4A;\"\n      >We've hosted all of these weddings. And then some.</div>\n    \n                </td>\n              </tr>\n            \n              <tr>\n                <td\n                   align=\"left\" class=\"body-text\" style=\"font-size:0px;padding:0 0 20px;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Poppins, Helvetica, Arial, sans-serif;font-size:16px;line-height:1.7;text-align:left;color:#4A4A4A;\"\n      >The estate doesn't dictate your style — it adapts to it. The brick and the trees and the chandeliers provide a beautiful backdrop, but what you create here is completely yours. Cameron Estate is a canvas for your vision, not a template that everything has to fit into.</div>\n    \n                </td>\n              </tr>\n            <!-- IMAGE PLACEHOLDER: Reception Styling --><!--\n          <mj-image\n            src=\"https://storage.googleapis.com/msgsndr/G7APqyfJ6lyi4l28noZj/media/6989327a38f77a2717eb4653.jpg\"\n            alt=\"Reception Styling\"\n            width=\"520px\"\n            border-radius=\"6px\"\n            padding=\"0\" />\n          -->\n        </tbody>\n      </table>\n    \n      </div>\n    \n          <!--[if mso | IE]></td></tr></table><![endif]-->\n              </td>\n            </tr>\n          </tbody>\n        </table>\n        \n      </div>\n    \n      \n      <!--[if mso | IE]></td></tr></table><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"\" role=\"presentation\" style=\"width:600px;\" width=\"600\" bgcolor=\"#FFFFFF\" ><tr><td style=\"line-height:0px;font-size:0px;mso-line-height-rule:exactly;\"><![endif]-->\n    \n      \n      <div  style=\"background:#FFFFFF;background-color:#FFFFFF;margin:0px auto;max-width:600px;\">\n        \n        <table\n           align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"background:#FFFFFF;background-color:#FFFFFF;width:100%;\"\n        >\n          <tbody>\n            <tr>\n              <td\n                 style=\"direction:ltr;font-size:0px;padding:30px 40px;text-align:center;\"\n              >\n                <!--[if mso | IE]><table role=\"presentation\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"><tr><td class=\"\" style=\"vertical-align:top;width:520px;\" ><![endif]-->\n            \n      <div\n         class=\"mj-column-per-100 mj-outlook-group-fix\" style=\"font-size:0px;text-align:left;direction:ltr;display:inline-block;vertical-align:top;width:100%;\"\n      >\n        \n      <table\n         border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"vertical-align:top;\" width=\"100%\"\n      >\n        <tbody>\n          \n              <tr>\n                <td\n                   align=\"left\" style=\"font-size:0px;padding:0 0 15px;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Cormorant Garamond, Georgia, serif;font-size:24px;font-weight:500;line-height:1.6;text-align:left;color:#D4AF37;\"\n      >That's Why We Created a Pinterest Board for You</div>\n    \n                </td>\n              </tr>\n            \n              <tr>\n                <td\n                   align=\"left\" class=\"body-text\" style=\"font-size:0px;padding:0 0 15px;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Poppins, Helvetica, Arial, sans-serif;font-size:16px;line-height:1.7;text-align:left;color:#4A4A4A;\"\n      >I put together a collection of real weddings from Cameron Estate — couples who trusted us with their day and created something beautiful. It shows just how versatile this space is:</div>\n    \n                </td>\n              </tr>\n            \n              <tr>\n                <td\n                   align=\"left\" class=\"body-text\" style=\"font-size:0px;padding:6px 0;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Poppins, Helvetica, Arial, sans-serif;font-size:16px;line-height:1.7;text-align:left;color:#4A4A4A;\"\n      >✓ Romantic spring garden ceremonies under the trees<br/>\n            ✓ Elegant candlelit receptions in the Spring View Ballroom<br/>\n            ✓ Dramatic fall weddings with rich burgundy and gold<br/>\n            ✓ Intimate winter celebrations by the fireplace<br/>\n            ✓ Bold, modern designs that felt totally fresh and unexpected</div>\n    \n                </td>\n              </tr>\n            \n              <tr>\n                <td\n                   align=\"left\" style=\"font-size:0px;padding:10px 25px;padding-top:20px;padding-bottom:10px;word-break:break-word;\"\n                >\n                  \n      <table\n         border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"border-collapse:separate;line-height:100%;\"\n      >\n        <tbody>\n          <tr>\n            <td\n               align=\"center\" bgcolor=\"#D4AF37\" role=\"presentation\" style=\"border:none;border-radius:4px;cursor:auto;mso-padding-alt:14px 35px;background:#D4AF37;\" valign=\"middle\"\n            >\n              <a\n                 href=\"{{trigger_link.kI4aVPLShqovAveOSkbk}}\" style=\"display:inline-block;background:#D4AF37;color:#FFFFFF;font-family:Poppins, Helvetica, Arial, sans-serif;font-size:16px;font-weight:500;line-height:1.6;margin:0;text-decoration:none;text-transform:none;padding:14px 35px;mso-padding-alt:0px;border-radius:4px;\" target=\"_blank\"\n              >\n                Browse Our Pinterest Board →\n              </a>\n            </td>\n          </tr>\n        </tbody>\n      </table>\n    \n                </td>\n              </tr>\n            \n        </tbody>\n      </table>\n    \n      </div>\n    \n          <!--[if mso | IE]></td></tr></table><![endif]-->\n              </td>\n            </tr>\n          </tbody>\n        </table>\n        \n      </div>\n    \n      \n      <!--[if mso | IE]></td></tr></table><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"\" role=\"presentation\" style=\"width:600px;\" width=\"600\" bgcolor=\"#FDFCFA\" ><tr><td style=\"line-height:0px;font-size:0px;mso-line-height-rule:exactly;\"><![endif]-->\n    \n      \n      <div  style=\"background:#FDFCFA;background-color:#FDFCFA;margin:0px auto;max-width:600px;\">\n        \n        <table\n           align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"background:#FDFCFA;background-color:#FDFCFA;width:100%;\"\n        >\n          <tbody>\n            <tr>\n              <td\n                 style=\"direction:ltr;font-size:0px;padding:30px 40px;text-align:center;\"\n              >\n                <!--[if mso | IE]><table role=\"presentation\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"><tr><td class=\"\" style=\"vertical-align:top;width:520px;\" ><![endif]-->\n            \n      <div\n         class=\"mj-column-per-100 mj-outlook-group-fix\" style=\"font-size:0px;text-align:left;direction:ltr;display:inline-block;vertical-align:top;width:100%;\"\n      >\n        \n      <table\n         border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"vertical-align:top;\" width=\"100%\"\n      >\n        <tbody>\n          \n              <tr>\n                <td\n                   align=\"left\" class=\"body-text\" style=\"font-size:0px;padding:0 0 20px;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Poppins, Helvetica, Arial, sans-serif;font-size:16px;line-height:1.7;text-align:left;color:#4A4A4A;\"\n      >Grab a coffee, open Pinterest, and spend a few minutes scrolling through. See what makes you say \"oh, <strong>that's</strong> us.\" That's the fun part of wedding planning — discovering what really resonates with you.</div>\n    \n                </td>\n              </tr>\n            \n              <tr>\n                <td\n                   align=\"left\" class=\"body-text\" style=\"font-size:0px;padding:0;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Poppins, Helvetica, Arial, sans-serif;font-size:16px;line-height:1.7;text-align:left;color:#4A4A4A;\"\n      >And if something catches your eye, or if you want to talk through how your vision would work here at Cameron Estate, just hit reply. I genuinely love these conversations — talking about wedding design and what makes a day feel special is literally my favorite thing.</div>\n    \n                </td>\n              </tr>\n            \n              <tr>\n                <td\n                   align=\"left\" style=\"font-size:0px;padding:30px 0 0;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Cormorant Garamond, Georgia, serif;font-size:22px;font-weight:500;line-height:1.6;text-align:left;color:#2C3E50;\"\n      >Talk soon,<br/>Lisa</div>\n    \n                </td>\n              </tr>\n            \n        </tbody>\n      </table>\n    \n      </div>\n    \n          <!--[if mso | IE]></td></tr></table><![endif]-->\n              </td>\n            </tr>\n          </tbody>\n        </table>\n        \n      </div>\n    \n      \n      <!--[if mso | IE]></td></tr></table><![endif]-->\n    \n    <!-- Footer Divider -->\n      \n      <!--[if mso | IE]><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"\" role=\"presentation\" style=\"width:600px;\" width=\"600\" bgcolor=\"#FFFFFF\" ><tr><td style=\"line-height:0px;font-size:0px;mso-line-height-rule:exactly;\"><![endif]-->\n    \n      \n      <div  style=\"background:#FFFFFF;background-color:#FFFFFF;margin:0px auto;max-width:600px;\">\n        \n        <table\n           align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"background:#FFFFFF;background-color:#FFFFFF;width:100%;\"\n        >\n          <tbody>\n            <tr>\n              <td\n                 style=\"direction:ltr;font-size:0px;padding:20px 40px 0;text-align:center;\"\n              >\n                <!--[if mso | IE]><table role=\"presentation\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"><tr><td class=\"\" style=\"vertical-align:top;width:520px;\" ><![endif]-->\n            \n      <div\n         class=\"mj-column-per-100 mj-outlook-grou