  "name": "001 E Day 3 - Stories",
  "subject": "",
  "previewText": "",
  "html": "<!--\nSubject: \"We knew within minutes\"\nPreview Text: Three couples share what made them choose Cameron Estate. Their stories might help you decide...\n-->\n<!doctype html>\n<html lang=\"und\" dir=\"auto\" xmlns=\"http://www.w3.org/1999/xhtml\" xmlns:v=\"urn:schemas-microsoft-com:vml\" xmlns:o=\"urn:schemas-microsoft-com:office:office\">\n  <head>\n    <title></title>\n    <!--[if !mso]><!-->\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n    <!--<![endif]-->\n    <meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n    <style type=\"text/css\">\n      #outlook a { padding:0; }\n      body { margin:0;padding:0;-webkit-text-size-adjust:100%;-ms-text-size-adjust:100%; }\n      table, td { border-collapse:collapse;mso-table-lspace:0pt;mso-table-rspace:0pt; }\n      img { border:0;height:auto;line-height:100%; outline:none;text-decoration:none;-ms-interpolation-mode:bicubic; }\n      p { display:block;margin:13px 0; }\n    </style>\n    <!--[if mso]>\n    <noscript>\n    <xml>\n    <o:OfficeDocumentSettings>\n      <o:AllowPNG/>\n      <o:PixelsPerInch>96</o:PixelsPerInch>\n    </o:OfficeDocumentSettings>\n    </xml>\n    </noscript>\n    <![endif]-->\n    <!--[if lte mso 11]>\n    <style type=\"text/css\">\n      .mj-outlook-group-fix { width:100% !important; }\n    </style>\n    <![endif]-->\n    \n      <!--[if !mso]><!-->\n        <link href=\"https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&display=swap\" rel=\"stylesheet\" type=\"text/css\">\n<link href=\"https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap\" rel=\"stylesheet\" type=\"text/css\">\n        <style type=\"text/css\">\n          @import url(https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&display=swap);\n@import url(https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap);\n        </style>\n      <!--<![endif]-->\n\n    \n    \n    <style type=\"text/css\">\n      @media only screen and (min-width:480px) {\n        .mj-column-per-100 { width:100% !important; max-width: 100%; }\n      }\n    </style>\n    <style media=\"screen and (min-width:480px)\">\n      .moz-text-html .mj-column-per-100 { width:100% !important; max-width: 100%; }\n    </style>\n    \n    \n  \n    \n    <style type=\"text/css\">\n\n    @media only screen and (max-width:479px) {\n      table.mj-full-width-mobile { width: 100% !important; }\n      td.mj-full-width-mobile { width: auto !important; }\n    }\n  \n    </style>\n     \n    <style type=\"text/css\">\n/* Progressive enhancement for email clients with CSS support */\n      .heading-primary {\n        font-family: 'Cormorant Garamond', Georgia, serif !important;\n        color: #2C3E50 !important;\n        font-weight: 500 !important;\n        font-size: 32px !important;\n        line-height: 1.2 !important;\n      }\n      .heading-secondary {\n        font-family: 'Cormorant Garamond', Georgia, serif !important;\n        color: #2C3E50 !important;\n        font-weight: 500 !important;\n        font-size: 24px !important;\n        line-height: 1.3 !important;\n      }\n      .body-text {\n        font-family: 'Poppins', Helvetica, Arial, sans-serif !important;\n        color: #4A4A4A !important;\n        font-size: 16px !important;\n        line-height: 1.6 !important;\n      }\n      .signature-text {\n        font-family: 'Cormorant Garamond', Georgia, serif !important;\n        color: #2C3E50 !important;\n        font-size: 20px !important;\n        font-weight: 500 !important;\n      }\n      .testimonial-quote {\n        font-family: 'Cormorant Garamond', Georgia, serif !important;\n        color: #2C3E50 !important;\n        font-size: 20px !important;\n        font-style: italic !important;\n        line-height: 1.4 !important;\n      }\n      .testimonial-attribution {\n        font-family: 'Poppins', Helvetica, Arial, sans-serif !important;\n        color: #666 !important;\n        font-size: 14px !important;\n        font-weight: 500 !important;\n      }\n      .quote-text {\n        font-family: 'Cormorant Garamond', Georgia, serif !important;\n        color: #2C3E50 !important;\n        font-size: 22px !important;\n        font-style: italic !important;\n        line-height: 1.4 !important;\n      }\n      /* Mobile optimizations */\n      @media only screen and (max-width: 480px) {\n        .heading-primary { font-size: 26px !important; }\n        .heading-secondary { font-size: 21px !important; }\n        .body-text div { font-size: 14px !important; line-height: 1.6 !important; }\n        .testimonial-quote div { font-size: 18px !important; }\n        .quote-text div { font-size: 20px !important; }\n        /* Full-width mobile buttons */\n        .cta-primary table,\n        .cta-secondary table { width: 100% !important; }\n        .cta-primary a,\n        .cta-secondary a { display: block !important; width: 100% !important; }\n        .footer-email a { font-size: 11px !important; }\n        .responsive-link a { font-size: 12px !important; word-break: break-all; }\n      }\n    </style>\n    <!-- Fonts: Cormorant Garamond (headings) and Poppins (body) -->\n<!-- Global Attributes -->\n<!-- Custom Styles -->\n<!-- Preview Text -->\n  <!-- outlook-fixes-applied --></head>\n  <body style=\"word-spacing:normal;background-color:#FAFAFA;\">\n    \n    <div style=\"display:none;font-size:1px;color:#ffffff;line-height:1px;max-height:0px;max-width:0px;opacity:0;overflow:hidden;\">Three couples share what made them choose Cameron Estate. Their stories might help you decide...</div>\n  \n    \n      <div\n         aria-roledescription=\"email\" style=\"background-color:#FAFAFA;\" role=\"article\" lang=\"und\" dir=\"auto\"\n      >\n        <!-- Opening Content (above the fold) --><!-- Gallery Section (between opening and body) --><!-- Body Content -->\n      \n      <!--[if mso | IE]><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"\" role=\"presentation\" style=\"width:600px;\" width=\"600\" bgcolor=\"#FDFCFA\" ><tr><td style=\"line-height:0px;font-size:0px;mso-line-height-rule:exactly;\"><![endif]-->\n    \n      \n      <div  style=\"background:#FDFCFA;background-color:#FDFCFA;margin:0px auto;max-width:600px;\">\n        \n        <table\n           align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"background:#FDFCFA;background-color:#FDFCFA;width:100%;\"\n        >\n          <tbody>\n            <tr>\n              <td\n                 style=\"direction:ltr;font-size:0px;padding:40px 40px 20px;text-align:center;\"\n              >\n                <!--[if mso | IE]><table role=\"presentation\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"><tr><td class=\"\" style=\"vertical-align:top;width:520px;\" ><![endif]-->\n            \n      <div\n         class=\"mj-column-per-100 mj-outlook-group-fix\" style=\"font-size:0px;text-align:left;direction:ltr;display:inline-block;vertical-align:top;width:100%;\"\n      >\n        \n      <table\n         border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"vertical-align:top;\" width=\"100%\"\n      >\n        <tbody>\n          \n              <tr>\n                <td\n                   align=\"left\" style=\"font-size:0px;padding:0 0 25px;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Cormorant Garamond, Georgia, serif;font-size:28px;font-weight:500;line-height:1.6;text-align:left;color:#2C3E50;\"\n      >{{contact.first_name}},</div>\n    \n                </td>\n              </tr>\n            \n              <tr>\n                <td\n                   align=\"left\" class=\"body-text\" style=\"font-size:0px;padding:0 0 15px;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Poppins, Helvetica, Arial, sans-serif;font-size:16px;line-height:1.7;text-align:left;color:#4A4A4A;\"\n      >I wanted to share something with you that I think might help as you continue exploring venues.</div>\n    \n                </td>\n              </tr>\n            \n              <tr>\n                <td\n                   align=\"left\" class=\"body-text\" style=\"font-size:0px;padding:0 0 15px;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Poppins, Helvetica, Arial, sans-serif;font-size:16px;line-height:1.7;text-align:left;color:#4A4A4A;\"\n      >When couples tour Cameron Estate — people just like you — they often tell me something interesting: they knew within the first few minutes whether it was right for them. Not because we have the fanciest ballroom in Lancaster County, or the most acres, or the highest search ranking.</div>\n    \n                </td>\n              </tr>\n            \n              <tr>\n                <td\n                   align=\"left\" class=\"body-text\" style=\"font-size:0px;padding:0;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Poppins, Helvetica, Arial, sans-serif;font-size:16px;line-height:1.7;text-align:left;color:#4A4A4A;\"\n      >They knew because they could genuinely picture their wedding happening here. They weren't looking at <em>a</em> wedding anymore — they were seeing <em>their</em> wedding.</div>\n    \n                </td>\n              </tr>\n            \n        </tbody>\n      </table>\n    \n      </div>\n    \n          <!--[if mso | IE]></td></tr></table><![endif]-->\n              </td>\n            </tr>\n          </tbody>\n        </table>\n        \n      </div>\n    \n      \n      <!--[if mso | IE]></td></tr></table><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"\" role=\"presentation\" style=\"width:600px;\" width=\"600\" bgcolor=\"#FFFFFF\" ><tr><td style=\"line-height:0px;font-size:0px;mso-line-height-rule:exactly;\"><![endif]-->\n    \n      \n      <div  style=\"background:#FFFFFF;background-color:#FFFFFF;margin:0px auto;max-width:600px;\">\n        \n        <table\n           align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"background:#FFFFFF;background-color:#FFFFFF;width:100%;\"\n        >\n          <tbody>\n            <tr>\n              <td\n                 style=\"direction:ltr;font-size:0px;padding:30px 40px 10px;text-align:center;\"\n              >\n                <!--[if mso | IE]><table role=\"presentation\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"><tr><td class=\"\" style=\"vertical-align:top;width:520px;\" ><![endif]-->\n            \n      <div\n         class=\"mj-column-per-100 mj-outlook-group-fix\" style=\"font-size:0px;text-align:left;direction:ltr;display:inline-block;vertical-align:top;width:100%;\"\n      >\n        \n      <table\n         border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"vertical-align:top;\" width=\"100%\"\n      >\n        <tbody>\n          \n              <tr>\n                <td\n                   align=\"left\" style=\"font-size:0px;padding:0 0 20px;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Cormorant Garamond, Georgia, serif;font-size:24px;font-weight:500;line-height:1.6;text-align:left;color:#D4AF37;\"\n      >What Recent Couples Are Saying</div>\n    \n                </td>\n              </tr>\n            \n        </tbody>\n      </table>\n    \n      </div>\n    \n          <!--[if mso | IE]></td></tr></table><![endif]-->\n              </td>\n            </tr>\n          </tbody>\n        </table>\n        \n      </div>\n    \n      \n      <!--[if mso | IE]></td></tr></table><![endif]-->\n    \n    <!-- Testimonial 1 -->\n      \n      <!--[if mso | IE]><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"\" role=\"presentation\" style=\"width:600px;\" width=\"600\" bgcolor=\"#FFFFFF\" ><tr><td style=\"line-height:0px;font-size:0px;mso-line-height-rule:exactly;\"><![endif]-->\n    \n      \n      <div  style=\"background:#FFFFFF;background-color:#FFFFFF;margin:0px auto;max-width:600px;\">\n        \n        <table\n           align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"background:#FFFFFF;background-color:#FFFFFF;width:100%;\"\n        >\n          <tbody>\n            <tr>\n              <td\n                 style=\"direction:ltr;font-size:0px;padding:0 40px 40px;text-align:center;\"\n              >\n                <!--[if mso | IE]><table role=\"presentation\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"><tr><td class=\"\" style=\"vertical-align:top;width:520px;\" ><![endif]-->\n            \n      <div\n         class=\"mj-column-per-100 mj-outlook-group-fix\" style=\"font-size:0px;text-align:left;direction:ltr;display:inline-block;vertical-align:top;width:100%;\"\n      >\n        \n      <table\n         border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"vertical-align:top;\" width=\"100%\"\n      >\n        <tbody>\n          \n              <tr>\n                <td\n                   align=\"left\" class=\"testimonial-quote\" style=\"font-size:0px;padding:0 0 15px;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Poppins, Helvetica, Arial, sans-serif;font-size:16px;font-style:italic;line-height:1.7;text-align:left;color:#555555;\"\n      >\"We looked at five venues over two weekends. Cameron Estate was the only one where we could actually see our day unfolding. The all-inclusive approach meant we weren't stressed about coordinating vendors, arguing about chair rental fees, or hiring a day-of coordinator. We could just enjoy planning our wedding instead of managing a construction project.\"</div>\n    \n                </td>\n              </tr>\n            \n              <tr>\n                <td\n                   align=\"left\" class=\"testimonial-attribution\" style=\"font-size:0px;padding:0 0 25px;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Poppins, Helvetica, Arial, sans-serif;font-size:15px;font-weight:bold;line-height:1.6;text-align:left;color:#2C3E50;\"\n      >— Jennifer & Michael, October 2025</div>\n    \n                </td>\n              </tr>\n            <!-- IMAGE PLACEHOLDER: Cameron Estate Grounds --><!--\n          <mj-image\n            src=\"https://storage.googleapis.com/msgsndr/G7APqyfJ6lyi4l28noZj/media/6989327a0a7fd1cf9141c545.jpg\"\n            alt=\"Cameron Estate Grounds\"\n            width=\"520px\"\n            border-radius=\"6px\"\n            padding=\"0\" />\n          -->\n        </tbody>\n      </table>\n    \n      </div>\n    \n          <!--[if mso | IE]></td></tr></table><![endif]-->\n              </td>\n            </tr>\n          </tbody>\n        </table>\n        \n      </div>\n    \n      \n      <!--[if mso | IE]></td></tr></table><![endif]-->\n    \n    <!-- Testimonial 2 -->\n      \n      <!--[if mso | IE]><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"\" role=\"presentation\" style=\"width:600px;\" width=\"600\" bgcolor=\"#F5F1EB\" ><tr><td style=\"line-height:0px;font-size:0px;mso-line-height-rule:exactly;\"><![endif]-->\n    \n      \n      <div  style=\"background:#F5F1EB;background-color:#F5F1EB;margin:0px auto;max-width:600px;\">\n        \n        <table\n           align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"background:#F5F1EB;background-color:#F5F1EB;width:100%;\"\n        >\n          <tbody>\n            <tr>\n              <td\n                 style=\"direction:ltr;font-size:0px;padding:40px;text-align:center;\"\n              >\n                <!--[if mso | IE]><table role=\"presentation\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"><tr><td class=\"\" style=\"vertical-align:top;width:520px;\" ><![endif]-->\n            \n      <div\n         class=\"mj-column-per-100 mj-outlook-group-fix\" style=\"font-size:0px;text-align:left;direction:ltr;display:inline-block;vertical-align:top;width:100%;\"\n      >\n        \n      <table\n         border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"vertical-align:top;\" width=\"100%\"\n      >\n        <tbody>\n          \n              <tr>\n                <td\n                   align=\"left\" class=\"testimonial-quote\" style=\"font-size:0px;padding:0 0 15px;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Poppins, Helvetica, Arial, sans-serif;font-size:16px;font-style:italic;line-height:1.7;text-align:left;color:#555555;\"\n      >\"Our families loved Cameron Estate as much as we did. Having everyone stay on-site for the weekend — gathering Friday night, celebrating all day Saturday, brunching together Sunday — made our wedding feel less like a stressful event and more like a celebration with the people we love most. Our parents still talk about how special that made the whole experience.\"</div>\n    \n                </td>\n              </tr>\n            \n              <tr>\n                <td\n                   align=\"left\" class=\"testimonial-attribution\" style=\"font-size:0px;padding:0 0 25px;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Poppins, Helvetica, Arial, sans-serif;font-size:15px;font-weight:bold;line-height:1.6;text-align:left;color:#2C3E50;\"\n      >— Rachel & David, June 2025</div>\n    \n                </td>\n              </tr>\n            <!-- IMAGE PLACEHOLDER: Celebrating with family --><!--\n          <mj-image\n            src=\"https://storage.googleapis.com/msgsndr/G7APqyfJ6lyi4l28noZj/media/6989327a38f77a2717eb4653.jpg\"\n            alt=\"Celebrating with family\"\n            width=\"520px\"\n            border-radius=\"6px\"\n            padding=\"0\" />\n          -->\n        </tbody>\n      </table>\n    \n      </div>\n    \n          <!--[if mso | IE]></td></tr></table><![endif]-->\n              </td>\n            </tr>\n          </tbody>\n        </table>\n        \n      </div>\n    \n      \n      <!--[if mso | IE]></td></tr></table><![endif]-->\n    \n    <!-- Testimonial 3 -->\n      \n      <!--[if mso | IE]><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"\" role=\"presentation\" style=\"width:600px;\" width=\"600\" bgcolor=\"#FFFFFF\" ><tr><td style=\"line-height:0px;font-size:0px;mso-line-height-rule:exactly;\"><![endif]-->\n    \n      \n      <div  style=\"background:#FFFFFF;background-color:#FFFFFF;margin:0px auto;max-width:600px;\">\n        \n        <table\n           align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"background:#FFFFFF;background-color:#FFFFFF;width:100%;\"\n        >\n          <tbody>\n            <tr>\n              <td\n                 style=\"direction:ltr;font-size:0px;padding:40px;text-align:center;\"\n              >\n                <!--[if mso | IE]><table role=\"presentation\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"><tr><td class=\"\" style=\"vertical-align:top;width:520px;\" ><![endif]-->\n            \n      <div\n         class=\"mj-column-per-100 mj-outlook-group-fix\" style=\"font-size:0px;text-align:left;direction:ltr;display:inline-block;vertical-align:top;width:100%;\"\n      >\n        \n      <table\n         border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"vertical-align:top;\" width=\"100%\"\n      >\n        <tbody>\n          \n              <tr>\n                <td\n                   align=\"left\" class=\"testimonial-quote\" style=\"font-size:0px;padding:0 0 15px;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Poppins, Helvetica, Arial, sans-serif;font-size:16px;font-style:italic;line-height:1.7;text-align:left;color:#555555;\"\n      >\"The pricing was crystal clear from our first conversation with Lisa. No surprises, no hidden fees, no 'oh by the way this costs extra' showing up three months before the wedding. That peace of mind — knowing exactly what we were paying for and what it included — was worth absolutely everything. We could focus on the fun parts of planning instead of worrying about the budget.\"</div>\n    \n                </td>\n              </tr>\n            \n              <tr>\n                <td\n                   align=\"left\" class=\"testimonial-attribution\" style=\"font-size:0px;padding:0 0 25px;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Poppins, Helvetica, Arial, sans-serif;font-size:15px;font-weight:bold;line-height:1.6;text-align:left;color:#2C3E50;\"\n      >— Amanda & Chris, September 2024</div>\n    \n                </td>\n              </tr>\n            <!-- IMAGE PLACEHOLDER: Elegant details --><!--\n          <mj-image\n            src=\"https://storage.googleapis.com/msgsndr/G7APqyfJ6lyi4l28noZj/media/6989327a0708e4880ea07007.jpg\"\n            alt=\"Elegant details\"\n            width=\"520px\"\n            border-radius=\"6px\"\n            padding=\"0\" />\n          -->\n        </tbody>\n      </table>\n    \n      </div>\n    \n          <!--[if mso | IE]></td></tr></table><![endif]-->\n              </td>\n            </tr>\n          </tbody>\n        </table>\n        \n      </div>\n    \n      \n      <!--[if mso | IE]></td></tr></table><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"\" role=\"presentation\" style=\"width:600px;\" width=\"600\" bgcolor=\"#FDFCFA\" ><tr><td style=\"line-height:0px;font-size:0px;mso-line-height-rule:exactly;\"><![endif]-->\n    \n      \n      <div  style=\"background:#FDFCFA;background-color:#FDFCFA;margin:0px auto;max-width:600px;\">\n        \n        <table\n           align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"background:#FDFCFA;background-color:#FDFCFA;width:100%;\"\n        >\n          <tbody>\n            <tr>\n              <td\n                 style=\"direction:ltr;font-size:0px;padding:30px 40px;text-align:center;\"\n              >\n                <!--[if mso | IE]><table role=\"presentation\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"><tr><td class=\"\" style=\"vertical-align:top;width:520px;\" ><![endif]-->\n            \n      <div\n         class=\"mj-column-per-100 mj-outlook-group-fix\" style=\"font-size:0px;text-align:left;direction:ltr;display:inline-block;vertical-align:top;width:100%;\"\n      >\n        \n      <table\n         border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"vertical-align:top;\" width=\"100%\"\n      >\n        <tbody>\n          \n              <tr>\n                <td\n                   align=\"left\" class=\"body-text\" style=\"font-size:0px;padding:0 0 20px;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Poppins, Helvetica, Arial, sans-serif;font-size:16px;line-height:1.7;text-align:left;color:#4A4A4A;\"\n      >I don't know if Cameron Estate is the right fit for your celebration — truly, only you can decide that. But if you're still exploring your options and haven't found that moment of clarity yet, I'd love to give you the same experience these couples had: a chance to walk the grounds, see the spaces, and envision your own wedding day here.</div>\n    \n                </td>\n              </tr>\n            <!--\n          <mj-button \n            href=\"{{ links.book_tour }}\" \n            background-color=\"#D4AF37\" \n            color=\"#FFFFFF\"\n            border-radius=\"4px\"\n            font-size=\"16px\"\n            font-weight=\"500\"\n            inner-padding=\"14px 35px\"\n            align=\"left\"\n            padding-bottom=\"25px\">\n            Schedule Your Private Tour\n          </mj-button>\n          -->\n              <tr>\n                <td\n                   align=\"left\" class=\"body-text\" style=\"font-size:0px;padding:0;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Poppins, Helvetica, Arial, sans-serif;font-size:16px;line-height:1.7;text-align:left;color:#4A4A4A;\"\n      >Ready to see Cameron Estate in person? Just reply with a few dates that work for you, and I'll get you on the calendar. I'm here whenever you're ready. And honestly? I would genuinely love to hear your love story — how you met, what you're envisioning, what matters most to you about your wedding day.</div>\n    \n                </td>\n              </tr>\n            \n              <tr>\n                <td\n                   align=\"left\" style=\"font-size:0px;padding:30px 0 0;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Cormorant Garamond, Georgia, serif;font-size:22px;font-weight:500;line-height:1.6;text-align:left;color:#2C3E50;\"\n      >Talk soon,<br/>Lisa</div>\n    \n                </td>\n              </tr>\n            \n        </tbody>\n      </table>\n    \n      </div>\n    \n          <!--[if mso | IE]></td></tr></table><![endif]-->\n              </td>\n            </tr>\n          </tbody>\n        </table>\n        \n      </div>\n    \n      \n      <!--[if mso | IE]></td></tr></table><![endif]-->\n    \n    <!-- Footer Divider -->\n      \n      <!--[if mso | IE]><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"\" role=\"presentation\" style=\"width:600px;\" wid