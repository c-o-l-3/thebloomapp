l-fill-color:#2C3E50;}#ize0u9{color:#ccc;}#ieojan{color:#2C3E50;text-decoration:none;margin:0 5px;mso-style-textfill-fill-color:#2C3E50;}#iwx8lu{color:#ccc;}#irywc1{color:#2C3E50;text-decoration:none;margin:0 5px;mso-style-textfill-fill-color:#2C3E50;}@media only screen and (min-width: 480px){.mj-column-per-100{width:100% !important;max-width:100%;}}@media only screen and (max-width: 480px){.body-text div{font-size:14px !important;line-height:1.6 !important;}.testimonial-quote div{font-size:18px !important;}.quote-text div{font-size:20px !important;}.cta-primary table, .cta-secondary table{width:100% !important;}.cta-primary a, .cta-secondary a{display:block !important;width:100% !important;}.footer-email a{font-size:11px !important;}.responsive-link a{font-size:12px !important;word-break:break-all;}}@media only screen and (max-width: 479px){table.mj-full-width-mobile{width:100% !important;}td.mj-full-width-mobile{width:auto !important;}}\n  </style>\n<!-- outlook-fixes-applied --></head>\n<body>\n<title></title><meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\"><meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"><link href=\"https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&amp;display=swap\" rel=\"stylesheet\" type=\"text/css\"><link href=\"https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&amp;display=swap\" rel=\"stylesheet\" type=\"text/css\"><div id=\"ihdy\">You're probably wondering about deposits, cancellations, and what-ifs. Let me answer those now...</div><div aria-roledescription=\"email\" role=\"article\" lang=\"und\" dir=\"auto\" id=\"ix2hn\"><!-- Opening Content (above the fold) --><!-- Gallery Section (between opening and body) --><!-- Body Content --><!--[if mso | IE]><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"\" role=\"presentation\" style=\"width:600px;\" width=\"600\" bgcolor=\"#FDFCFA\" ><tr><td style=\"line-height:0px;font-size:0px;mso-line-height-rule:exactly;\"><![endif]--><div id=\"i5k2e\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" id=\"i8jqg\"><tbody><tr><td id=\"ia46y\"><!--[if mso | IE]><table role=\"presentation\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"><tr><td class=\"\" style=\"vertical-align:top;width:520px;\" ><![endif]--><div class=\"mj-column-per-100 mj-outlook-group-fix\" id=\"ity92\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" width=\"100%\" id=\"i4bgg\"><tbody><tr><td align=\"left\" id=\"ikflf\"><div id=\"iknpx\">{{contact.first_name}},</div></td></tr><tr><td align=\"left\" class=\"body-text\" id=\"ij0hj\"><div id=\"ixzs2\">Twelve days into your venue search, and you're probably asking yourself a lot of the same questions that every couple asks at this stage. Let me address what I hear most often \u2014 directly and honestly.</div></td></tr></tbody></table></div><!--[if mso | IE]></td></tr></table><![endif]--></td></tr></tbody></table></div><!--[if mso | IE]></td></tr></table><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"\" role=\"presentation\" style=\"width:600px;\" width=\"600\" bgcolor=\"#FFFFFF\" ><tr><td style=\"line-height:0px;font-size:0px;mso-line-height-rule:exactly;\"><![endif]--><div id=\"ii5r5\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" id=\"ilq8f\"><tbody><tr><td id=\"i38ml\"><!--[if mso | IE]><table role=\"presentation\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"><tr><td class=\"\" style=\"vertical-align:top;width:520px;\" ><![endif]--><div class=\"mj-column-per-100 mj-outlook-group-fix\" id=\"iuqap\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" width=\"100%\" id=\"i3xdx\"><tbody><tr><td align=\"left\" id=\"izlgy\"><div id=\"ibz9i\">\"What if we find something better after we book?\"</div></td></tr><tr><td align=\"left\" class=\"body-text\" id=\"i1a57\"><div id=\"ieepb\">You might. That's the nature of exploring \u2014 you never know what you might find around the next corner.</div></td></tr><tr><td align=\"left\" class=\"body-text\" id=\"ii2gb\"><div id=\"iw5g5\">But here's what I want you to consider: you've now seen Cameron Estate. You know what we offer, what our spaces look like, what's included in our pricing, and how we work with couples. You've developed clarity on what matters to you by seeing what's available.</div></td></tr><tr><td align=\"left\" class=\"body-text\" id=\"ixfwv\"><div id=\"i1t2z\">If another venue offers something significantly different \u2014 a feature you genuinely need that we don't have, a date we don't have available, a price point that works better for your budget \u2014 then you'll know. And you can make an informed decision. But that clarity only comes from seeing what's actually out there, which you're doing.</div></td></tr></tbody></table></div><!--[if mso | IE]></td></tr></table><![endif]--></td></tr></tbody></table></div><!--[if mso | IE]></td></tr></table><![endif]--><!-- Visual Break 1 --><!-- IMAGE PLACEHOLDER: Cameron Estate Inn Exterior --><!--\n      <mj-section padding=\"0 40px 40px\" background-color=\"#FFFFFF\">\n        <mj-column>\n          <mj-image\n            src=\"https://storage.googleapis.com/msgsndr/G7APqyfJ6lyi4l28noZj/media/6989327a0a7fd1ecad41c546.jpg\"\n            alt=\"Cameron Estate Inn Exterior\"\n            width=\"520px\"\n            border-radius=\"6px\"\n            padding=\"0\" />\n        </mj-column>\n      </mj-section>\n      --><!--[if mso | IE]><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"\" role=\"presentation\" style=\"width:600px;\" width=\"600\" bgcolor=\"#F5F1EB\" ><tr><td style=\"line-height:0px;font-size:0px;mso-line-height-rule:exactly;\"><![endif]--><div id=\"icmsy\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" id=\"im6fh\"><tbody><tr><td id=\"ihbd3\"><!--[if mso | IE]><table role=\"presentation\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"><tr><td class=\"\" style=\"vertical-align:top;width:520px;\" ><![endif]--><div class=\"mj-column-per-100 mj-outlook-group-fix\" id=\"ixhkb\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" width=\"100%\" id=\"i62vl\"><tbody><tr><td align=\"left\" id=\"i8ebs\"><div id=\"ioep2\">\"Is the pricing really final? Are there hidden fees?\"</div></td></tr><tr><td align=\"left\" class=\"body-text\" id=\"iag3g\"><div id=\"ihp64\">Yes. Your proposal includes exactly what we discussed \u2014 your all-inclusive price for your estimated guest count, covers all food, beverage, venue access, rentals, and coordination services. No surprises. No hidden fees. No add-ons that you didn't expect showing up three months before your wedding.</div></td></tr><tr><td align=\"left\" class=\"body-text\" id=\"iqks3\"><div id=\"i4jft\">If your guest count changes significantly, we'll adjust accordingly. But there are no secret \"service fees,\" no \"admin charges,\" no \"setup costs\" that appear later. <br><!--[if mso]>&nbsp;<![endif]--><br>The number we quote is the number you pay.</div></td></tr></tbody></table></div><!--[if mso | IE]></td></tr></table><![endif]--></td></tr></tbody></table></div><!--[if mso | IE]></td></tr></table><![endif]--><!-- Visual Break 2 --><!-- IMAGE PLACEHOLDER: No hidden fees --><!--\n      <mj-section padding=\"0 40px 40px\" background-color=\"#F5F1EB\">\n        <mj-column>\n          <mj-image\n            src=\"https://storage.googleapis.com/msgsndr/G7APqyfJ6lyi4l28noZj/media/6989327a38f77a2717eb4653.jpg\"\n            alt=\"No hidden fees\"\n            width=\"520px\"\n            border-radius=\"6px\"\n            padding=\"0\" />\n        </mj-column>\n      </mj-section>\n      --><!--[if mso | IE]><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"\" role=\"presentation\" style=\"width:600px;\" width=\"600\" bgcolor=\"#FFFFFF\" ><tr><td style=\"line-height:0px;font-size:0px;mso-line-height-rule:exactly;\"><![endif]--><div id=\"ifonp\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" id=\"i5fva\"><tbody><tr><td id=\"i2at4\"><!--[if mso | IE]></td></tr></table><![endif]--></td></tr></tbody></table></div><!--[if mso | IE]></td></tr></table><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"\" role=\"presentation\" style=\"width:600px;\" width=\"600\" bgcolor=\"#F5F1EB\" ><tr><td style=\"line-height:0px;font-size:0px;mso-line-height-rule:exactly;\"><![endif]--><div id=\"itjh0c\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" id=\"iorc3g\"><tbody><tr><td id=\"iqig3b\"><!--[if mso | IE]><table role=\"presentation\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"><tr><td class=\"\" style=\"vertical-align:top;width:520px;\" ><![endif]--><div class=\"mj-column-per-100 mj-outlook-group-fix\" id=\"ispwo8\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" width=\"100%\" id=\"ic2j63\"><tbody><tr><td align=\"left\" id=\"ifv6y3\"><div id=\"i7a6de\">\"How do we actually know it's the right choice?\"</div></td></tr><tr><td align=\"left\" class=\"body-text\" id=\"ire1ci\"><div id=\"ibnb5i\">Honestly? You won't know completely until your wedding day. That's the honest truth about planning a celebration this important \u2014 you're making decisions years in advance about something you can't fully experience until it happens.</div></td></tr><tr><td align=\"left\" class=\"body-text\" id=\"ir8tif\"><div id=\"i6f16t\">But here's what couples tell us: they felt <strong>relief</strong>, not anxiety, when they made their decision. They felt ready to stop searching and start planning. They could picture their day here, and that picture felt right.</div></td></tr><tr><td align=\"left\" class=\"body-text\" id=\"ipxb7z\"><div id=\"ityvz6\">If you're feeling anxious or uncertain, keep exploring. If you're feeling relief and excitement when you think about Cameron Estate, that's worth paying attention to.</div></td></tr></tbody></table></div><!--[if mso | IE]></td></tr></table><![endif]--></td></tr></tbody></table></div><!--[if mso | IE]></td></tr></table><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"\" role=\"presentation\" style=\"width:600px;\" width=\"600\" bgcolor=\"#FFFFFF\" ><tr><td style=\"line-height:0px;font-size:0px;mso-line-height-rule:exactly;\"><![endif]--><div id=\"i7b1sv\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" id=\"ijx4p1\"><tbody><tr><td id=\"i0dfdy\"><!--[if mso | IE]><table role=\"presentation\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"><tr><td class=\"\" style=\"vertical-align:top;width:520px;\" ><![endif]--><div class=\"mj-column-per-100 mj-outlook-group-fix\" id=\"i7f5qg\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" width=\"100%\" id=\"iop3fd\"><tbody><tr><td align=\"left\" id=\"iqxafj\"><div id=\"i27xjn\">\"What happens next if we book?\"</div></td></tr><tr><td align=\"left\" class=\"body-text\" id=\"ijt5km\"><div id=\"ixd70h\">Here's what the rest of your wedding planning journey looks like with Cameron Estate:</div></td></tr><tr><td align=\"left\" class=\"body-text\" id=\"it2eal\"><div id=\"idvg2i\"><strong>Step 1:</strong> You select your date and secure it with your deposit. The date is officially yours.</div></td></tr><tr><td align=\"left\" class=\"body-text\" id=\"i6s8q6\"><div id=\"if9ywf\"><strong>Step 2:</strong> We schedule a comprehensive planning meeting \u2014 either in person or virtual, whatever works for you \u2014 to discuss your vision in detail. Colors, flowers, menu preferences, timeline, all of it.</div></td></tr><tr><td align=\"left\" class=\"body-text\" id=\"igmcnn\"><div id=\"inwc6o\"><strong>Step 3:</strong> You receive your dedicated coordinator \u2014 the person who will guide you through every step of the planning process, answer your questions, help you make decisions, and manage all the details.</div></td></tr><tr><td align=\"left\" class=\"body-text\" id=\"iungtv\"><div id=\"iz2x9o\"><strong>Step 4:</strong> We handle all vendor coordination. Your coordinator works with your florist, photographer, DJ, and any other vendors to make sure everyone is on the same page.</div></td></tr><tr><td align=\"left\" class=\"body-text\" id=\"ijdv5z\"><div id=\"iyr9eu\"><strong>Step 5:</strong> We manage timeline planning, setup, and day-of execution. You show up on your wedding day, and we handle everything.</div></td></tr><tr><td align=\"left\" class=\"body-text\" id=\"i5vz3a\"><div id=\"iz0izh\">That's the beauty of having one team manage everything: you get to actually enjoy your wedding day instead of managing it.</div></td></tr></tbody></table></div><!--[if mso | IE]></td></tr></table><![endif]--></td></tr></tbody></table></div><!--[if mso | IE]></td></tr></table><![endif]--><!-- Visual Break 3 --><!-- IMAGE PLACEHOLDER: Enjoying your wedding day --><!--\n      <mj-section padding=\"0 40px 40px\" background-color=\"#FFFFFF\">\n        <mj-column>\n          <mj-image\n            src=\"https://storage.googleapis.com/msgsndr/G7APqyfJ6lyi4l28noZj/media/6989327a38f77a2717eb4653.jpg\"\n            alt=\"Enjoying your wedding day\"\n            width=\"520px\"\n            border-radius=\"6px\"\n            padding=\"0\" />\n        </mj-column>\n      </mj-section>\n      --><!--[if mso | IE]><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"\" role=\"presentation\" style=\"width:600px;\" width=\"600\" bgcolor=\"#FDFCFA\" ><tr><td style=\"line-height:0px;font-size:0px;mso-line-height-rule:exactly;\"><![endif]--><div id=\"i1swcs\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" id=\"i12z0a\"><tbody><tr><td id=\"ijmwmx\"><!--[if mso | IE]><table role=\"presentation\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"><tr><td class=\"\" style=\"vertical-align:top;width:520px;\" ><![endif]--><div class=\"mj-column-per-100 mj-outlook-group-fix\" id=\"i7ha82\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" width=\"100%\" id=\"i64fil\"><tbody><tr><td align=\"left\" id=\"i6mu1e\"><div id=\"i34zcm\">Questions I Didn't Anticipate?</div></td></tr><tr><td align=\"left\" class=\"body-text\" id=\"ifwbfl\"><div id=\"iif3p9\">Let's talk. I'm here to answer anything I haven't covered.</div></td></tr><!--\n          <mj-button \n            href=\"{{ links.calendar }}\" \n            background-color=\"#D4AF37\" \n            color=\"#FFFFFF\"\n            border-radius=\"4px\"\n            font-size=\"16px\"\n            font-weight=\"500\"\n            inner-padding=\"14px 35px\"\n            align=\"left\">\n            Schedule a Call\n          </mj-button>\n          --><tr><td align=\"left\" class=\"body-text\" id=\"itablj\"><div id=\"i2lkw2\">Or reach out however works best for you:</div></td></tr><tr><td align=\"left\" class=\"body-text\" id=\"iccj1l\"><div id=\"ie6e3i\">Email: <span class=\"responsive-link\"><a href=\"mailto:ceiweddings@cameronestateinn.com\" id=\"i3qefj\"><!--[if mso]><font color=\"#2C3E50\"><![endif]-->ceiweddings@cameronestateinn.com<!--[if mso]></font><![endif]--></a></span><br>\n            Phone: 717-725-4831</div></td></tr><tr><td align=\"left\" class=\"body-text\" id=\"ip9bsj\"><div id=\"ijvl64\">Take your time. Good decisions aren't rushed \u2014 but our calendar is real, and availability does shift as couples make decisions. If you've been thinking about Cameron Estate, I hope you'll give us the chance to show you around.</div></td></tr></tbody></table></div><!--[if mso | IE]></td></tr></table><![endif]--></td></tr></tbody></table></div><!--[if mso | 