color:#ccc;}#ihm6js{color:#2C3E50;text-decoration:none;margin:0 5px;mso-style-textfill-fill-color:#2C3E50;}#i399bq{color:#ccc;}#iij4ck{color:#2C3E50;text-decoration:none;margin:0 5px;mso-style-textfill-fill-color:#2C3E50;}@media only screen and (min-width: 480px){.mj-column-per-100{width:100% !important;max-width:100%;}}@media only screen and (max-width: 480px){.body-text div{font-size:14px !important;line-height:1.6 !important;}.testimonial-quote div{font-size:18px !important;}.quote-text div{font-size:20px !important;}.cta-primary table, .cta-secondary table{width:100% !important;}.cta-primary a, .cta-secondary a{display:block !important;width:100% !important;}.footer-email a{font-size:11px !important;}.responsive-link a{font-size:12px !important;word-break:break-all;}}@media only screen and (max-width: 479px){table.mj-full-width-mobile{width:100% !important;}td.mj-full-width-mobile{width:auto !important;}}\n  </style>\n<!-- outlook-fixes-applied --></head>\n<body>\n<body><title></title><meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\"/><meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link href=\"https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&display=swap\" rel=\"stylesheet\" type=\"text/css\"/><link href=\"https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap\" rel=\"stylesheet\" type=\"text/css\"/><div id=\"i1uh\">Not all all-inclusive packages are created equal. Here is exactly what is included in ours — and what you handle elsewhere...</div><div aria-roledescription=\"email\" role=\"article\" lang=\"und\" dir=\"auto\" id=\"i2ckt\"><!-- Opening Content (above the fold) --><!-- Gallery Section (between opening and body) --><!-- Body Content --><!--[if mso | IE]><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"\" role=\"presentation\" style=\"width:600px;\" width=\"600\" bgcolor=\"#FDFCFA\" ><tr><td style=\"line-height:0px;font-size:0px;mso-line-height-rule:exactly;\"><![endif]--><div id=\"irgv5\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" id=\"idtq1\"><tbody><tr><td id=\"i7qwt\"><!--[if mso | IE]><table role=\"presentation\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"><tr><td class=\"\" style=\"vertical-align:top;width:520px;\" ><![endif]--><div class=\"mj-column-per-100 mj-outlook-group-fix\" id=\"i04lw\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" width=\"100%\" id=\"iw1df\"><tbody><tr><td align=\"left\" id=\"iw6rk\"><div id=\"ilqp9\">{{contact.first_name}},</div></td></tr><tr><td align=\"left\" class=\"body-text\" id=\"ic41q\"><div id=\"i6dik\">You're probably seeing \"all-inclusive\" at every venue you research right now. Venue websites, wedding planning blogs, Instagram ads — everyone's using that term.</div></td></tr><tr><td align=\"left\" class=\"body-text\" id=\"izs24\"><div id=\"injhd\">But here's what I've learned after years in this industry: \"all-inclusive\" means something completely different at every single venue. There's no standard definition. It's a marketing term that gets thrown around without any real meaning behind it.</div></td></tr><tr><td align=\"left\" class=\"body-text\" id=\"iafoj\"><div id=\"i6rxx\">Let me show you exactly what it means at Cameron Estate. No marketing spin, no fine print hidden on page 12 of the contract — just a straightforward list of what's included when you book your wedding with us.</div></td></tr></tbody></table></div><!--[if mso | IE]></td></tr></table><![endif]--></td></tr></tbody></table></div><!--[if mso | IE]></td></tr></table><![endif]--><!-- IMAGE PLACEHOLDER: Cameron Estate Exterior --><!--\n      <mj-section padding=\"0 40px 40px\" background-color=\"#FDFCFA\">\n        <mj-column>\n          <mj-image\n            src=\"https://storage.googleapis.com/msgsndr/G7APqyfJ6lyi4l28noZj/media/6989327a0a7fd1ecad41c546.jpg\"\n            alt=\"Cameron Estate Exterior\"\n            width=\"520px\"\n            border-radius=\"6px\"\n            padding=\"0\" />\n        </mj-column>\n      </mj-section>\n      --><!--[if mso | IE]><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"\" role=\"presentation\" style=\"width:600px;\" width=\"600\" bgcolor=\"#FFFFFF\" ><tr><td style=\"line-height:0px;font-size:0px;mso-line-height-rule:exactly;\"><![endif]--><div id=\"if485\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" id=\"ir1sk\"><tbody><tr><td id=\"ipa1p\"><!--[if mso | IE]><table role=\"presentation\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"><tr><td class=\"\" style=\"vertical-align:top;width:520px;\" ><![endif]--><div class=\"mj-column-per-100 mj-outlook-group-fix\" id=\"ii1qt\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" width=\"100%\" id=\"ij58o\"><tbody><tr><td align=\"left\" id=\"ik8dx\"><div id=\"i4l6z\">What's Included: The Essentials</div></td></tr><tr><td align=\"left\" class=\"body-text\" id=\"it5ec\"><div id=\"ika4v\"><strong>Your Venue &amp; Ceremony Spaces:</strong><br/>\n            Your choice of ceremony location — Spring Garden or Conservatory — is included. Cocktail hour space. Your reception ballroom — Spring View Ballroom or Carriage House, depending on your guest count. No separate venue rental fee. No \"facility charge.\" You pay one set price that includes the spaces - no hidden fees - your proposal clearly shows the investment.</div></td></tr><tr><td align=\"left\" class=\"body-text\" id=\"igpcz\"><div id=\"ix54p\"><strong>Event Essentials:</strong><br/>\n            Tables and chairs for both ceremony and reception — included. Premium linens (tablecloths and napkins) in your choice of colors — included. Centerpiece vases and table decor elements — included. Dessert packages available. Cake cutting and service — included. Day of coordinator. Setup crew to transform the spaces according to your vision. Cleanup crew to handle everything after.</div></td></tr><tr><td align=\"left\" class=\"body-text\" id=\"ibtof\"><div id=\"ihrfg\"><strong>Getting Ready Spaces:</strong><br/>\n            Two private changing spaces provided for the couple to prepare before the ceremony. No need to book a hotel room just for getting ready — we have you covered right here on the estate.</div></td></tr></tbody></table></div><!--[if mso | IE]></td></tr></table><![endif]--></td></tr></tbody></table></div><!--[if mso | IE]></td></tr></table><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"\" role=\"presentation\" style=\"width:600px;\" width=\"600\" bgcolor=\"#F5F1EB\" ><tr><td style=\"line-height:0px;font-size:0px;mso-line-height-rule:exactly;\"><![endif]--><div id=\"is5co\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" id=\"id064\"><tbody><tr><td id=\"ivefe\"><!--[if mso | IE]><table role=\"presentation\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"><tr><td class=\"\" style=\"vertical-align:top;width:520px;\" ><![endif]--><div class=\"mj-column-per-100 mj-outlook-group-fix\" id=\"iv623\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" width=\"100%\" id=\"ifr9z\"><tbody><tr><td align=\"left\" id=\"i7r0h\"><div id=\"iulj8\">Food, Beverage &amp; Staff</div></td></tr><tr><td align=\"left\" class=\"body-text\" id=\"i91is\"><div id=\"iq0wd\"><strong>Food &amp; Beverage:</strong><br/>\n            Full plated dinner service with our experienced culinary team. <strong>Champagne toast</strong> (included in select packages). Luxury open bar featuring beer, wine, liquor, and all the mixers. Professional bartender services throughout your reception. All glassware, china, and flatware — nothing extra to rent, nothing to coordinate.</div></td></tr><tr><td align=\"left\" class=\"body-text\" id=\"iist0i\"><div id=\"iql24v\"><strong>Staffing &amp; Coordination:</strong><br/>\n            Your dedicated event coordinator who handles timeline planning, vendor coordination, and day-of management from contract signing to cake cutting. Professional wait staff for your plated dinner service. Bar staff throughout your reception. Setup and cleanup crew.</div></td></tr></tbody></table></div><!--[if mso | IE]></td></tr></table><![endif]--></td></tr></tbody></table></div><!--[if mso | IE]></td></tr></table><![endif]--><!-- IMAGE PLACEHOLDER: Table Setting Details --><!--\n      <mj-section padding=\"0 40px 40px\" background-color=\"#F5F1EB\">\n        <mj-column>\n          <mj-image\n            src=\"undefined\"\n            alt=\"Table Setting Details\"\n            width=\"520px\"\n            border-radius=\"6px\"\n            padding=\"0\" />\n        </mj-column>\n      </mj-section>\n      --><!--[if mso | IE]><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"\" role=\"presentation\" style=\"width:600px;\" width=\"600\" bgcolor=\"#FFFFFF\" ><tr><td style=\"line-height:0px;font-size:0px;mso-line-height-rule:exactly;\"><![endif]--><div id=\"ikc79c\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" id=\"itygbk\"><tbody><tr><td id=\"imw1lg\"><!--[if mso | IE]><table role=\"presentation\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"><tr><td class=\"\" style=\"vertical-align:top;width:520px;\" ><![endif]--><div class=\"mj-column-per-100 mj-outlook-group-fix\" id=\"im82qw\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" width=\"100%\" id=\"i8dwns\"><tbody><tr><td align=\"left\" id=\"i4klgu\"><div id=\"inogqj\">What You Handle Separately</div></td></tr><tr><td align=\"left\" class=\"body-text\" id=\"i4roqt\"><div id=\"ig3gv6\">(But We Have Great Recommendations!)</div></td></tr><tr><td align=\"left\" class=\"body-text\" id=\"iwh772\"><div id=\"i6wcwk\">• Flowers and floral design</div></td></tr><tr><td align=\"left\" class=\"body-text\" id=\"id3ojg\"><div id=\"ijoyqi\">• Photography and videography</div></td></tr><tr><td align=\"left\" class=\"body-text\" id=\"i74bg6\"><div id=\"ikbr4h\">• Music or DJ</div></td></tr><tr><td align=\"left\" class=\"body-text\" id=\"ibkbpl\"></td></tr><tr><td align=\"left\" class=\"body-text\" id=\"iccr0o\"><div id=\"i4s65b\">• Invitations and paper goods</div></td></tr><tr><td align=\"left\" class=\"body-text\" id=\"irxlwb\"><div id=\"ialc0h\">• Your dress, attire, rings</div></td></tr></tbody></table></div><!--[if mso | IE]></td></tr></table><![endif]--></td></tr></tbody></table></div><!--[if mso | IE]></td></tr></table><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"\" role=\"presentation\" style=\"width:600px;\" width=\"600\" bgcolor=\"#2C3E50\" ><tr><td style=\"line-height:0px;font-size:0px;mso-line-height-rule:exactly;\"><![endif]--><div id=\"ismrwh\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" id=\"i3mns1\"><tbody><tr><td id=\"im5768\"><!--[if mso | IE]><table role=\"presentation\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"><tr><td class=\"\" style=\"vertical-align:top;width:520px;\" ><![endif]--><div class=\"mj-column-per-100 mj-outlook-group-fix\" id=\"iz0wwh\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" width=\"100%\" id=\"iejqt4\"><tbody><tr><td align=\"center\" id=\"idx7fd\"><div id=\"i9d6ig\">\"The difference this makes in your planning experience is hard to overstate.\"</div></td></tr><tr><td align=\"center\" class=\"body-text\" id=\"iu1ojj\"><div id=\"itrv2v\">Instead of coordinating with a venue, caterer, rental company, bar service, day-of coordinator, and cleanup crew — you coordinate with one person at one place. Your planning becomes simpler. Your costs become clearer. Your wedding day becomes smoother.</div></td></tr></tbody></table></div><!--[if mso | IE]></td></tr></table><![endif]--></td></tr></tbody></table></div><!--[if mso | IE]></td></tr></table><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"\" role=\"presentation\" style=\"width:600px;\" width=\"600\" bgcolor=\"#FDFCFA\" ><tr><td style=\"line-height:0px;font-size:0px;mso-line-height-rule:exactly;\"><![endif]--><div id=\"ij68yc\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" id=\"ig5ohe\"><tbody><tr><td id=\"isu7ew\"><!--[if mso | IE]><table role=\"presentation\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"><tr><td class=\"\" style=\"vertical-align:top;width:520px;\" ><![endif]--><div class=\"mj-column-per-100 mj-outlook-group-fix\" id=\"iadpxi\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" width=\"100%\" id=\"i45k2v\"><tbody><tr><td align=\"left\" class=\"body-text\" id=\"i4xpj6\"><div id=\"ilnjzs\">I encourage you to compare this to other venues you're considering. Ask them specifically: \"What's included in your per-person price, and what costs extra?\" The details matter. The answers will be very revealing.</div></td></tr><tr><td align=\"left\" class=\"body-text\" id=\"i112of\"><div id=\"ii12ol\">Want to see how this all comes together at Cameron Estate? Reply with a few dates for your tour, and I'll show you every space, explain every detail, and answer every question you have.</div></td></tr><!--\n          <mj-button \n            href=\"{{ links.book_tour }}\" \n            background-color=\"#D4AF37\" \n            color=\"#FFFFFF\"\n            border-radius=\"4px\"\n            font-size=\"16px\"\n            font-weight=\"500\"\n            inner-padding=\"14px 35px\"\n            align=\"left\">\n            See It In Person\n          </mj-button>\n          --><tr><td align=\"left\" id=\"iz90aj\"><div id=\"ia674l\">Talk soon,<br/>Lisa</div></td></tr></tbody></table></div><!--[if mso | IE]></td></tr></table><![endif]--></