ins:wght@300;400;500;600&display=swap);\n        </style>\n      <!--<![endif]-->\n\n    \n    \n    <style type=\"text/css\">\n      @media only screen and (min-width:480px) {\n        .mj-column-per-100 { width:100% !important; max-width: 100%; }\n      }\n    </style>\n    <style media=\"screen and (min-width:480px)\">\n      .moz-text-html .mj-column-per-100 { width:100% !important; max-width: 100%; }\n    </style>\n    \n    \n  \n    \n    <style type=\"text/css\">\n\n    @media only screen and (max-width:479px) {\n      table.mj-full-width-mobile { width: 100% !important; }\n      td.mj-full-width-mobile { width: auto !important; }\n    }\n  \n    </style>\n     \n    <style type=\"text/css\">\n/* Progressive enhancement for email clients with CSS support */\n      .heading-primary {\n        font-family: 'Cormorant Garamond', Georgia, serif !important;\n        color: #2C3E50 !important;\n        font-weight: 500 !important;\n        font-size: 32px !important;\n        line-height: 1.2 !important;\n      }\n      .heading-secondary {\n        font-family: 'Cormorant Garamond', Georgia, serif !important;\n        color: #2C3E50 !important;\n        font-weight: 500 !important;\n        font-size: 24px !important;\n        line-height: 1.3 !important;\n      }\n      .body-text {\n        font-family: 'Poppins', Helvetica, Arial, sans-serif !important;\n        color: #4A4A4A !important;\n        font-size: 16px !important;\n        line-height: 1.6 !important;\n      }\n      .signature-text {\n        font-family: 'Cormorant Garamond', Georgia, serif !important;\n        color: #2C3E50 !important;\n        font-size: 20px !important;\n        font-weight: 500 !important;\n      }\n      .testimonial-quote {\n        font-family: 'Cormorant Garamond', Georgia, serif !important;\n        color: #2C3E50 !important;\n        font-size: 20px !important;\n        font-style: italic !important;\n        line-height: 1.4 !important;\n      }\n      .testimonial-attribution {\n        font-family: 'Poppins', Helvetica, Arial, sans-serif !important;\n        color: #666 !important;\n        font-size: 14px !important;\n        font-weight: 500 !important;\n      }\n      .quote-text {\n        font-family: 'Cormorant Garamond', Georgia, serif !important;\n        color: #2C3E50 !important;\n        font-size: 22px !important;\n        font-style: italic !important;\n        line-height: 1.4 !important;\n      }\n      /* Mobile optimizations */\n      @media only screen and (max-width: 480px) {\n        .heading-primary { font-size: 26px !important; }\n        .heading-secondary { font-size: 21px !important; }\n        .body-text div { font-size: 14px !important; line-height: 1.6 !important; }\n        .testimonial-quote div { font-size: 18px !important; }\n        .quote-text div { font-size: 20px !important; }\n        /* Full-width mobile buttons */\n        .cta-primary table,\n        .cta-secondary table { width: 100% !important; }\n        .cta-primary a,\n        .cta-secondary a { display: block !important; width: 100% !important; }\n        .footer-email a { font-size: 11px !important; }\n        .responsive-link a { font-size: 12px !important; word-break: break-all; }\n      }\n    </style>\n    <!-- Fonts: Cormorant Garamond (headings) and Poppins (body) -->\n<!-- Global Attributes -->\n<!-- Custom Styles -->\n<!-- Preview Text -->\n  <!-- outlook-fixes-applied --></head>\n  <body style=\"word-spacing:normal;background-color:#FAFAFA;\">\n    \n    <div style=\"display:none;font-size:1px;color:#ffffff;line-height:1px;max-height:0px;max-width:0px;opacity:0;overflow:hidden;\">I haven't heard from you, which tells me you've likely found your venue. Congratulations, and best wishes...</div>\n  \n    \n      <div\n         aria-roledescription=\"email\" style=\"background-color:#FAFAFA;\" role=\"article\" lang=\"und\" dir=\"auto\"\n      >\n        <!-- Opening Content (above the fold) --><!-- Gallery Section (between opening and body) --><!-- Body Content -->\n      \n      <!--[if mso | IE]><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"\" role=\"presentation\" style=\"width:600px;\" width=\"600\" bgcolor=\"#FDFCFA\" ><tr><td style=\"line-height:0px;font-size:0px;mso-line-height-rule:exactly;\"><![endif]-->\n    \n      \n      <div  style=\"background:#FDFCFA;background-color:#FDFCFA;margin:0px auto;max-width:600px;\">\n        \n        <table\n           align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"background:#FDFCFA;background-color:#FDFCFA;width:100%;\"\n        >\n          <tbody>\n            <tr>\n              <td\n                 style=\"direction:ltr;font-size:0px;padding:40px 40px 20px;text-align:center;\"\n              >\n                <!--[if mso | IE]><table role=\"presentation\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"><tr><td class=\"\" style=\"vertical-align:top;width:520px;\" ><![endif]-->\n            \n      <div\n         class=\"mj-column-per-100 mj-outlook-group-fix\" style=\"font-size:0px;text-align:left;direction:ltr;display:inline-block;vertical-align:top;width:100%;\"\n      >\n        \n      <table\n         border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"vertical-align:top;\" width=\"100%\"\n      >\n        <tbody>\n          \n              <tr>\n                <td\n                   align=\"left\" style=\"font-size:0px;padding:0 0 25px;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Cormorant Garamond, Georgia, serif;font-size:28px;font-weight:500;line-height:1.6;text-align:left;color:#2C3E50;\"\n      >{{contact.first_name}},</div>\n    \n                </td>\n              </tr>\n            \n              <tr>\n                <td\n                   align=\"left\" class=\"body-text\" style=\"font-size:0px;padding:0 0 15px;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Poppins, Helvetica, Arial, sans-serif;font-size:16px;line-height:1.7;text-align:left;color:#4A4A4A;\"\n      >I haven't heard from you in a bit, so I'm assuming you've likely found your wedding venue or decided to go in a different direction.</div>\n    \n                </td>\n              </tr>\n            \n              <tr>\n                <td\n                   align=\"left\" class=\"body-text\" style=\"font-size:0px;padding:0 0 15px;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Poppins, Helvetica, Arial, sans-serif;font-size:16px;line-height:1.7;text-align:left;color:#4A4A4A;\"\n      >I just wanted to send one last note to say: <strong>congratulations</strong>.</div>\n    \n                </td>\n              </tr>\n            \n              <tr>\n                <td\n                   align=\"left\" class=\"body-text\" style=\"font-size:0px;padding:0;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Poppins, Helvetica, Arial, sans-serif;font-size:16px;line-height:1.7;text-align:left;color:#4A4A4A;\"\n      >Planning a wedding is a big journey. Wherever you've chosen to celebrate, I truly hope it's everything you've envisioned. I hope the day is full of joy, that the weather is perfect, and that you're surrounded by people who love you.</div>\n    \n                </td>\n              </tr>\n            \n        </tbody>\n      </table>\n    \n      </div>\n    \n          <!--[if mso | IE]></td></tr></table><![endif]-->\n              </td>\n            </tr>\n          </tbody>\n        </table>\n        \n      </div>\n    \n      \n      <!--[if mso | IE]></td></tr></table><![endif]-->\n    \n    <!-- Visual Break --><!-- IMAGE PLACEHOLDER: Best wishes from Cameron Estate --><!--\n      <mj-section padding=\"0 40px 40px\" background-color=\"#FDFCFA\">\n        <mj-column>\n          <mj-image\n            src=\"undefined\"\n            alt=\"Best wishes from Cameron Estate\"\n            width=\"520px\"\n            border-radius=\"6px\"\n            padding=\"0\" />\n        </mj-column>\n      </mj-section>\n      -->\n      \n      <!--[if mso | IE]><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"\" role=\"presentation\" style=\"width:600px;\" width=\"600\" bgcolor=\"#FFFFFF\" ><tr><td style=\"line-height:0px;font-size:0px;mso-line-height-rule:exactly;\"><![endif]-->\n    \n      \n      <div  style=\"background:#FFFFFF;background-color:#FFFFFF;margin:0px auto;max-width:600px;\">\n        \n        <table\n           align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"background:#FFFFFF;background-color:#FFFFFF;width:100%;\"\n        >\n          <tbody>\n            <tr>\n              <td\n                 style=\"direction:ltr;font-size:0px;padding:30px 40px;text-align:center;\"\n              >\n                <!--[if mso | IE]><table role=\"presentation\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"><tr><td class=\"\" style=\"vertical-align:top;width:520px;\" ><![endif]-->\n            \n      <div\n         class=\"mj-column-per-100 mj-outlook-group-fix\" style=\"font-size:0px;text-align:left;direction:ltr;display:inline-block;vertical-align:top;width:100%;\"\n      >\n        \n      <table\n         border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"vertical-align:top;\" width=\"100%\"\n      >\n        <tbody>\n          \n              <tr>\n                <td\n                   align=\"left\" class=\"body-text\" style=\"font-size:0px;padding:0 0 20px;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Poppins, Helvetica, Arial, sans-serif;font-size:16px;line-height:1.7;text-align:left;color:#4A4A4A;\"\n      >If you <em>are</em> still looking and just haven't had a chance to reply \u2014 life gets busy! \u2014 I'm still here. You can always reach back out to me, even months from now. If we have the date available, we'd love to host you.</div>\n    \n                </td>\n              </tr>\n            \n              <tr>\n                <td\n                   align=\"left\" class=\"body-text\" style=\"font-size:0px;padding:0 0 20px;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Poppins, Helvetica, Arial, sans-serif;font-size:16px;line-height:1.7;text-align:left;color:#4A4A4A;\"\n      >But for now, I'll take you off my follow-up list so I'm not clogging your inbox.</div>\n    \n                </td>\n              </tr>\n            \n              <tr>\n                <td\n                   align=\"left\" style=\"font-size:0px;padding:10px 0 0;word-break:break-word;\"\n                >\n                  \n      <div\n         style=\"font-family:Cormorant Garamond, Georgia, serif;font-size:22px;font-weight:500;line-height:1.6;text-align:left;color:#2C3E50;\"\n      >All the best,<br/>Lisa</div>\n    \n                </td>\n              </tr>\n            \n        </tbody>\n      </table>\n    \n      </div>\n    \n          <!--[if mso | IE]></td></tr></table><![endif]-->\n              </td>\n            </tr>\n          </tbody>\n        </table>\n        \n      </div>\n    \n      \n      <!--[if mso | IE]></td></tr></table><![endif]-->\n    \n    <!-- Footer CTAs -->\n<!--[if mso | IE]><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"\" role=\"presentation\" style=\"width:600px;\" width=\"600\" bgcolor=\"#FFFFFF\"><tr><td style=\"line-height:0px;font-size:0px;mso-line-height-rule:exactly;\"><![endif]-->\n<div style=\"background:#FFFFFF;margin:0px auto;max-width:600px;\">\n  <table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"background:#FFFFFF;wid