# Database
DATABASE_URL="postgresql://bloom:bloom_password@localhost:5432/journey_builder"

# API Configuration
PORT=3001
NODE_ENV=development
API_BASE_URL="http://localhost:3001"

# Authentication
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="24h"

# CORS
CORS_ORIGIN="http://localhost:5173"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Redis (for distributed rate limiting)
REDIS_URL=redis://localhost:6379
# For Redis with auth: redis://username:password@localhost:6379

# Admin Token (for rate limit admin UI)
ADMIN_TOKEN=your-secure-admin-token-change-in-production

# IP Whitelist (comma-separated IPs exempt from rate limiting)
RATE_LIMIT_IP_WHITELIST=127.0.0.1,::1

# GHL Integration
GHL_API_KEY=""
GHL_BASE_URL="https://services.leadconnectorhq.com"