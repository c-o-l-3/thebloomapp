model RateLimitTier {
  id                  Int       @id @default(autoincrement())
  name                String    @unique @db.VarChar(50)
  displayName         String    @map("display_name") @db.VarChar(100)
  description         String?
  requestsPerMinute   Int       @map("requests_per_minute") @default(60)
