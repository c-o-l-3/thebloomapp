generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id              String   @id @default(uuid())
  slug            String   @unique
  name            String
  locationId      String?  @unique @map("location_id")
  ghlLocationId   String?  @map("ghl_location_id")
  industry        String?
  website         String?
  status          String   @default("active")
  settings        Json     @default("{}")
  config          Json     @default("{}")
  rateLimitTierId Int?     @map("rate_limit_tier_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  pipelines       Pipeline[]
  journeys        Journey[]
  templates       Template[]
  workflows       Workflow[]
  clientUsers     ClientUser[]
  syncHistory     SyncHistory[]
  analyticsEvents JourneyAnalyticsEvent[]
  journeyMetrics  JourneyPerformanceMetrics[]
  touchpointMetrics TouchpointPerformanceMetrics[]
  abTestResults   ABTestResult[]
  funnelStages    JourneyFunnelStage[]
  analyticsSummary ClientAnalyticsSummary[]
  fieldMappings   FieldMapping[]
  workflowTriggers WorkflowTriggerV2[]
  workflowExecutions WorkflowExecution[]
  
  // Client Portal relations
  changeRequests  ChangeRequest[]
  brandVoiceSettings BrandVoiceSettings?
  assets          ClientAsset[]
  portalUsers     ClientPortalUser[]
  
  // Webhook system relations
  webhookConfigs  WebhookConfig[]
  syncedContacts  SyncedContact[]
  syncedAppointments SyncedAppointment[]
  formSubmissions FormSubmission[]
  emailEvents     EmailEvent[]
  opportunityStageHistory OpportunityStageHistory[]

  // A/B Testing relations
  abTests         JourneyABTest[]
  abTestVariants  JourneyABTestVariant[]
  abTestParticipants ABTestParticipant[]
  abTestEvents    ABTestEvent[]
  abTestDailyStats ABTestDailyStats[]

  // Rate limiting relations
  rateLimitTier   RateLimitTier? @relation(fields: [rateLimitTierId], references: [id], onDelete: SetNull)
  apiKeys         ApiKey[]

  @@index([slug])
  @@index([status])
  @@index([ghlLocationId])
  @@index([rateLimitTierId])
  @@map("clients")
}

model Pipeline {
  id          String   @id @default(uuid())
  clientId    String   @map("client_id")
  name        String
  pipelineId  String?  @map("pipeline_id")
  stages      Json     @default("[]")
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  journeys    Journey[]

  @@index([clientId])
  @@map("pipelines")
}

model Journey {
  id              String    @id @default(uuid())
  clientId        String    @map("client_id")
  pipelineId      String?   @map("pipeline_id")
  name            String
  slug            String?
  description     String?
  category        String?
  status          String    @default("draft")
  version         Int       @default(1)
  triggerConfig   Json?     @map("trigger_config")
  goal            String?
  metadata        Json      @default("{}")
  publishedAt     DateTime? @map("published_at")
  approvedAt      DateTime? @map("approved_at")
  analyticsEnabled Boolean  @default(true) @map("analytics_enabled")
  analyticsConfig Json      @default("{}") @map("analytics_config")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  client          Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  pipeline        Pipeline? @relation(fields: [pipelineId], references: [id], onDelete: SetNull)
  touchpoints     Touchpoint[]
  versions        JourneyVersion[]
  approvals       Approval[]
  analyticsEvents JourneyAnalyticsEvent[]
  performanceMetrics JourneyPerformanceMetrics[]
  touchpointMetrics TouchpointPerformanceMetrics[]
  abTestResults   ABTestResult[]
  funnelStages    JourneyFunnelStage[]

  // A/B Testing relations
  abTests         JourneyABTest[]
  abTestVariants  JourneyABTestVariant[]

  @@index([clientId])
  @@index([status])
  @@index([category])
  @@index([clientId, status])
  @@map("journeys")
}

model Touchpoint {
  id              String   @id @default(uuid())
  journeyId       String   @map("journey_id")
  name            String
  type            String
  orderIndex      Int      @map("order_index")
  content         Json
  config          Json     @default("{}")
  position        Json?
  ghlTemplateId   String?  @map("ghl_template_id")
  status          String   @default("draft")
  nextTouchpointId String? @map("next_touchpoint_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  journey         Journey  @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  analyticsEvents JourneyAnalyticsEvent[]
  performanceMetrics TouchpointPerformanceMetrics[]

  @@index([journeyId])
  @@index([type])
  @@index([journeyId, orderIndex])
  @@map("touchpoints")
}

model Template {
  id              String    @id @default(uuid())
  clientId        String?   @map("client_id")
  name            String
  type            String
  ghlTemplateId   String?   @unique @map("ghl_template_id")
  content         Json
  variables       Json      @default("[]")
  status          String    @default("draft")
  lastSynced      DateTime? @map("last_synced")
  syncStatus      String?   @map("sync_status")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  client          Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([ghlTemplateId])
  @@index([type])
  @@map("templates")
}

model Workflow {
  id          String   @id @default(uuid())
  clientId    String   @map("client_id")
  name        String
  workflowId  String?  @map("workflow_id")
  status      String   @default("active")
  trigger     Json
  actions     Json     @default("[]")
  notes       Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  triggers    WorkflowTriggerV2[]
  executions  WorkflowExecution[]

  @@index([clientId])
  @@map("workflows")
}

// Workflow Triggers V2 - P1 Q2 2026
model WorkflowTriggerV2 {
  id                String   @id @default(uuid())
  workflowId        String   @map("workflow_id")
  clientId          String   @map("client_id")
  name              String
  type              String   // contactCreated, stageChanged, emailOpened, linkClicked, formSubmitted, appointmentBooked
  status            String   @default("active") // active, paused, archived
  
  // Trigger configuration
  config            Json     @default("{}") // Type-specific configuration
  
  // Conditional logic
  conditions        Json?    @default("[]") // Array of condition groups
  conditionLogic    String   @default("and") @map("condition_logic") // and, or
  
  // Time-based settings
  timeDelay         Int?     @map("time_delay") // Delay in minutes
  timeDelayType     String?  @map("time_delay_type") // immediate, minutes, hours, days
  scheduleWindow    Json?    @map("schedule_window") // Business hours, days of week
  
  // Execution settings
  maxExecutions     Int?     @map("max_executions") // Per contact
  executionCooldown Int?     @map("execution_cooldown") // Minutes between executions
  
  // Deduplication
  dedupWindow       Int      @default(1440) @map("dedup_window") // Minutes (default 24h)
  dedupKey          String?  @map("dedup_key") // contactId, email, etc.
  
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  workflow          Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  client            Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  executions        TriggerExecution[]

  @@index([workflowId])
  @@index([clientId])
  @@index([type])
  @@index([status])
  @@index([clientId, type, status])
  @@map("workflow_triggers_v2")
}

// Workflow Execution Tracking
model WorkflowExecution {
  id                String   @id @default(uuid())
  workflowId        String   @map("workflow_id")
  clientId          String   @map("client_id")
  contactId         String?  @map("contact_id")
  triggerId         String?  @map("trigger_id")
  
  status            String   // pending, running, completed, failed, cancelled
  startedAt         DateTime @default(now()) @map("started_at")
  completedAt       DateTime? @map("completed_at")
  
  // Execution context
  context           Json?    // Contact data, event data, etc.
  results           Json?    // Action results
  error             String?
  
  // Analytics
  actionsTotal      Int      @default(0) @map("actions_total")
  actionsCompleted  Int      @default(0) @map("actions_completed")
  actionsFailed     Int      @default(0) @map("actions_failed")
  
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  workflow          Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  client            Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([clientId])
  @@index([contactId])
  @@index([status])
  @@index([startedAt])
  @@index([clientId, status])
  @@map("workflow_executions")
}

// Individual Trigger Executions
model TriggerExecution {
  id                String   @id @default(uuid())
  triggerId         String   @map("trigger_id")
  workflowId        String   @map("workflow_id")
  clientId          String   @map("client_id")
  contactId         String?  @map("contact_id")
  
  // Event data
  eventType         String   @map("event_type")
  eventData         Json     @map("event_data")
  
  // Execution result
  status            String   // triggered, suppressed, failed, conditions_not_met
  matchedConditions Json?    @map("matched_conditions")
  executionId       String?  @map("execution_id") // Links to WorkflowExecution
  
  // Deduplication
  dedupHash         String?  @map("dedup_hash")
  
  createdAt         DateTime @default(now()) @map("created_at")

  trigger           WorkflowTriggerV2 @relation(fields: [triggerId], references: [id], onDelete: Cascade)

  @@index([triggerId])
  @@index([clientId])
  @@index([contactId])
  @@index([eventType])
  @@index([status])
  @@index([createdAt])
  @@index([dedupHash])
  @@map("trigger_executions")
}

model JourneyVersion {
  id          String   @id @default(uuid())
  journeyId   String   @map("journey_id")
  version     Int
  snapshot    Json
  createdBy   String?  @map("created_by")
  changeLog   String?  @map("change_log")
  createdAt   DateTime @default(now()) @map("created_at")

  journey     Journey  @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  @@unique([journeyId, version])
  @@index([journeyId])
  @@index([journeyId, version])
  @@map("journey_versions")
}

model Approval {
  id            String    @id @default(uuid())
  journeyId     String    @map("journey_id")
  versionId     String?   @map("version_id")
  status        String
  comments      String?
  requestedBy   String?   @map("requested_by")
  reviewedBy    String?   @map("reviewed_by")
  reviewedAt    DateTime? @map("reviewed_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  journey       Journey   @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  @@index([journeyId])
  @@index([status])
  @@map("approvals")
}

model User {
  id            String       @id @default(uuid())
  email         String       @unique
  name          String?
  role          String       @default("editor")
  permissions   Json         @default("{}")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  clientUsers   ClientUser[]
  apiKeys       ApiKey[]
  apiKeysCreated ApiKey[] @relation(name: "ApiKeyCreator")

  @@map("users")
}

model ClientUser {
  id        String   @id @default(uuid())
  clientId  String   @map("client_id")
  userId    String   @map("user_id")
  role      String   @default("editor")
  createdAt DateTime @default(now()) @map("created_at")

  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clientId, userId])
  @@map("client_users")
}

model SyncHistory {
  id            String   @id @default(uuid())
  clientId      String?  @map("client_id")
  operation     String
  status        String
  itemsSynced   Int?     @map("items_synced")
  errors        String?
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")

  client        Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("sync_history")
}

model MigrationLog {
  id          String   @id @default(uuid())
  operation   String
  status      String
  details     Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("migration_logs")
}

// Analytics Models
model JourneyAnalyticsEvent {
  id            String    @id @default(uuid())
  journeyId     String    @map("journey_id")
  touchpointId  String?   @map("touchpoint_id")
  clientId      String    @map("client_id")
  eventType     String    @map("event_type")
  eventData     Json      @default("{}") @map("event_data")
  sessionId     String?   @map("session_id")
  contactId     String?   @map("contact_id")
  metadata      Json      @default("{}")
  createdAt     DateTime  @default(now()) @map("created_at")

  journey       Journey   @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  touchpoint    Touchpoint? @relation(fields: [touchpointId], references: [id], onDelete: SetNull)

  @@index([journeyId])
  @@index([clientId])
  @@index([eventType])
  @@index([createdAt])
  @@index([journeyId, eventType, createdAt])
  @@index([createdAt, clientId, eventType])
  @@map("journey_analytics_events")
}

model JourneyPerformanceMetrics {
  id                          String    @id @default(uuid())
  journeyId                   String    @map("journey_id")
  clientId                    String    @map("client_id")
  date                        DateTime  @db.Date
  totalContactsEntered        Int       @default(0) @map("total_contacts_entered")
  totalContactsCompleted      Int       @default(0) @map("total_contacts_completed")
  totalContactsDropped        Int       @default(0) @map("total_contacts_dropped")
  conversions                 Int       @default(0)
  conversionRate              Decimal   @default(0) @db.Decimal(5, 4) @map("conversion_rate")
  touchpointsSent             Int       @default(0) @map("touchpoints_sent")
  touchpointsDelivered        Int       @default(0) @map("touchpoints_delivered")
  touchpointsOpened           Int       @default(0) @map("touchpoints_opened")
  touchpointsClicked          Int       @default(0) @map("touchpoints_clicked")
  bounceRate                  Decimal   @default(0) @db.Decimal(5, 4) @map("bounce_rate")
  unsubscribeRate             Decimal   @default(0) @db.Decimal(5, 4) @map("unsubscribe_rate")
  avgTimeToCompletionMinutes  Int       @default(0) @map("avg_time_to_completion_minutes")
  avgTimeToConversionMinutes  Int       @default(0) @map("avg_time_to_conversion_minutes")
  totalValue                  Decimal   @default(0) @db.Decimal(12, 2) @map("total_value")
  avgValuePerConversion       Decimal   @default(0) @db.Decimal(12, 2) @map("avg_value_per_conversion")
  createdAt                   DateTime  @default(now()) @map("created_at")
  updatedAt                   DateTime  @updatedAt @map("updated_at")

  journey                     Journey   @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  client                      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([journeyId, date])
  @@index([journeyId])
  @@index([clientId])
  @@index([date])
  @@index([journeyId, date])
  @@index([date, clientId])
  @@map("journey_performance_metrics")
}

model TouchpointPerformanceMetrics {
  id              String    @id @default(uuid())
  touchpointId    String    @map("touchpoint_id")
  journeyId       String    @map("journey_id")
  clientId        String    @map("client_id")
  date            DateTime  @db.Date
  sent            Int       @default(0)
  delivered       Int       @default(0)
  opened          Int       @default(0)
  clicked         Int       @default(0)
  replied         Int       @default(0)
  bounced         Int       @default(0)
  unsubscribed    Int       @default(0)
  openRate        Decimal   @default(0) @db.Decimal(5, 4) @map("open_rate")
  clickRate       Decimal   @default(0) @db.Decimal(5, 4) @map("click_rate")
  replyRate       Decimal   @default(0) @db.Decimal(5, 4) @map("reply_rate")
  bounceRate      Decimal   @default(0) @db.Decimal(5, 4) @map("bounce_rate")
  dropOffs        Int       @default(0) @map("drop_offs")
  dropOffRate     Decimal   @default(0) @db.Decimal(5, 4) @map("drop_off_rate")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  touchpoint      Touchpoint @relation(fields: [touchpointId], references: [id], onDelete: Cascade)
  journey         Journey   @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  client          Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([touchpointId, date])
  @@index([touchpointId])
  @@index([journeyId])
  @@index([date])
  @@map("touchpoint_performance_metrics")
}

model ABTestResult {
  id                    String    @id @default(uuid())
  journeyId             String    @map("journey_id")
  touchpointId          String?   @map("touchpoint_id")
  clientId              String    @map("client_id")
  testName              String    @map("test_name")
  variantName           String    @map("variant_name")
  variantType           String    @map("variant_type")
  participants          Int       @default(0)
  trafficPercentage     Decimal   @default(0) @db.Decimal(5, 2) @map("traffic_percentage")
  conversions           Int       @default(0)
  conversionRate        Decimal   @default(0) @db.Decimal(5, 4) @map("conversion_rate")
  clicks                Int       @default(0)
  clickRate             Decimal   @default(0) @db.Decimal(5, 4) @map("click_rate")
  opens                 Int       @default(0)
  openRate              Decimal   @default(0) @db.Decimal(5, 4) @map("open_rate")
  confidenceLevel       Decimal   @default(0) @db.Decimal(5, 4) @map("confidence_level")
  isWinner              Boolean   @default(false) @map("is_winner")
  improvementPercentage Decimal   @default(0) @db.Decimal(6, 2) @map("improvement_percentage")
  startDate             DateTime? @map("start_date")
  endDate               DateTime? @map("end_date")
  status                String    @default("running")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  journey               Journey   @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  client                Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([journeyId])
  @@index([clientId])
  @@index([status])
  @@map("ab_test_results")
}

model JourneyFunnelStage {
  id                    String    @id @default(uuid())
  journeyId             String    @map("journey_id")
  clientId              String    @map("client_id")
  stageName             String    @map("stage_name")
  stageOrder            Int       @map("stage_order")
  enteredCount          Int       @default(0) @map("entered_count")
  completedCount        Int       @default(0) @map("completed_count")
  droppedCount          Int       @default(0) @map("dropped_count")
  conversionRate        Decimal   @default(0) @db.Decimal(5, 4) @map("conversion_rate")
  avgTimeInStageMinutes Int       @default(0) @map("avg_time_in_stage_minutes")
  touchpointId          String?   @map("touchpoint_id")
  date                  DateTime  @db.Date
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  journey               Journey   @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  client                Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([journeyId, stageName, date])
  @@index([journeyId])
  @@index([date])
  @@map("journey_funnel_stages")
}

model ClientAnalyticsSummary {
  id                          String    @id @default(uuid())
  clientId                    String    @map("client_id")
  date                        DateTime  @db.Date
  activeJourneys              Int       @default(0) @map("active_journeys")
  totalJourneyRuns            Int       @default(0) @map("total_journey_runs")
  totalConversions            Int       @default(0) @map("total_conversions")
  overallConversionRate       Decimal   @default(0) @db.Decimal(5, 4) @map("overall_conversion_rate")
  totalTouchpointsSent        Int       @default(0) @map("total_touchpoints_sent")
  avgOpenRate                 Decimal   @default(0) @db.Decimal(5, 4) @map("avg_open_rate")
  avgClickRate                Decimal   @default(0) @db.Decimal(5, 4) @map("avg_click_rate")
  avgBounceRate               Decimal   @default(0) @db.Decimal(5, 4) @map("avg_bounce_rate")
  avgTimeToConversionMinutes  Int       @default(0) @map("avg_time_to_conversion_minutes")
  totalRevenue                Decimal   @default(0) @db.Decimal(12, 2) @map("total_revenue")
  createdAt                   DateTime  @default(now()) @map("created_at")
  updatedAt                   DateTime  @updatedAt @map("updated_at")

  client                      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, date])
  @@index([clientId])
  @@index([date])
  @@map("client_analytics_summary")
}

// Custom Field Mapping Model - P1 Q2 2026
model FieldMapping {
  id                  String   @id @default(uuid())
  clientId            String   @map("client_id")
  sourceField         String   @map("source_field")
  sourceFieldType     String   @map("source_field_type")
  targetField         String   @map("target_field")
  targetFieldType     String   @map("target_field_type")
  targetSystem        String   @default("gohighlevel") @map("target_system")
  transformationRule  String?  @map("transformation_rule")
  validationRule      String?  @map("validation_rule")
  isRequired          Boolean  @default(false) @map("is_required")
  isActive            Boolean  @default(true) @map("is_active")
  description         String?
  exampleValue        String?  @map("example_value")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  client              Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, sourceField, targetSystem])
  @@index([clientId])
  @@index([targetSystem])
  @@index([isActive])
  @@map("field_mappings")
}

// Client Self-Service Portal Models - P2 Q2 2026

// Change Requests for content approval workflow
model ChangeRequest {
  id                String    @id @default(uuid())
  clientId          String    @map("client_id")
  journeyId         String?   @map("journey_id")
  touchpointId      String?   @map("touchpoint_id")
  
  // Request details
  type              String    // content_change, new_touchpoint, delete_touchpoint, brand_update, other
  title             String
  description       String
  proposedContent   Json?     @map("proposed_content")
  
  // Status workflow: pending_review -> in_review -> approved -> implemented
  //                -> rejected, -> cancelled
  status            String    @default("pending_review")
  priority          String    @default("medium") // low, medium, high, urgent
  
  // Requester info (client user)
  requestedBy       String    @map("requested_by")
  requestedByEmail  String    @map("requested_by_email")
  
  // Reviewer info (internal team)
  reviewedBy        String?   @map("reviewed_by")
  reviewNotes       String?   @map("review_notes")
  reviewedAt        DateTime? @map("reviewed_at")
  
  // Implementation tracking
  implementedAt     DateTime? @map("implemented_at")
  implementationNotes String? @map("implementation_notes")
  
  // Comments/activity log
  comments          Json      @default("[]")
  
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  client            Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([status])
  @@index([journeyId])
  @@index([clientId, status])
  @@index([createdAt])
  @@map("change_requests")
}

// Brand Voice Settings per client
model BrandVoiceSettings {
  id                String   @id @default(uuid())
  clientId          String   @unique @map("client_id")
  
  // Brand personality
  tone              String   @default("professional") // professional, casual, friendly, formal, playful, luxury
