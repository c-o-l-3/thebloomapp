// ============================================
// WEBHOOK SYSTEM - P1 Q3 2026
// Real-time sync with GoHighLevel webhooks
// ============================================

// Webhook Configuration - Stores webhook endpoints and settings per client
model WebhookConfig {
  id                String   @id @default(uuid())
  clientId          String   @map("client_id")
  
  // Webhook settings
  name              String
  description       String?
  webhookUrl        String   @map("webhook_url") // URL where GHL sends webhooks
  secretKey         String   @map("secret_key") // For signature verification
  
  // Event subscriptions
  subscribedEvents  Json     @default("[]") @map("subscribed_events") // Array of event types
  
  // Status
  status            String   @default("active") // active, paused, disabled
  
  // Retry configuration
  maxRetries        Int      @default(3) @map("max_retries")
  retryDelayMs      Int      @default(5000) @map("retry_delay_ms") // Base delay between retries
  
  // Rate limiting
  rateLimitPerMinute Int     @default(100) @map("rate_limit_per_minute")
  
  // Metadata
  lastSuccessAt     DateTime? @map("last_success_at")
  lastFailureAt     DateTime? @map("last_failure_at")
  totalDeliveries   Int      @default(0) @map("total_deliveries")
  failedDeliveries  Int      @default(0) @map("failed_deliveries")
  
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  client            Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  deliveries        WebhookDelivery[]

  @@index([clientId])
  @@index([status])
  @@map("webhook_configs")
}

// Webhook Delivery - Logs each webhook received from GHL
model WebhookDelivery {
  id                String   @id @default(uuid())
  configId          String   @map("config_id")
  clientId          String   @map("client_id")
  
  // Event details
  eventType         String   @map("event_type") // ContactCreate, ContactUpdate, etc.
  eventId           String?  @map("event_id") // GHL event ID for deduplication
  payload           Json     // Full webhook payload
  
  // Processing status
  status            String   @default("pending") // pending, processing, completed, failed, retrying
  
  // Signature verification
  signatureValid    Boolean? @map("signature_valid")
  signatureChecked  Boolean  @default(false) @map("signature_checked")
  
  // Processing results
  processedAt       DateTime? @map("processed_at")
  errorMessage      String?   @map("error_message")
  retryCount        Int       @default(0) @map("retry_count")
  nextRetryAt       DateTime? @map("next_retry_at")
  
  // Processing metadata
  processingTimeMs  Int?      @map("processing_time_ms")
  handlerResults    Json?     @map("handler_results") // Results from each handler
  
  // Raw request data
  headers           Json?     // HTTP headers
  ipAddress         String?   @map("ip_address")
  
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  config            WebhookConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([configId])
  @@index([clientId])
  @@index([eventType])
  @@index([status])
  @@index([eventId])
  @@index([createdAt])
  @@index([clientId, eventType, createdAt])
  @@map("webhook_deliveries")
}

// Synced Contact - Contacts synced from GHL via webhooks
model SyncedContact {
  id                String   @id @default(uuid())
  clientId          String   @map("client_id")
  
  // GHL Contact data
  ghlContactId      String   @unique @map("ghl_contact_id")
  email             String?
  phone             String?
  firstName         String?  @map("first_name")
  lastName          String?  @map("last_name")
  name              String?
  
  // Additional GHL data
  tags              Json     @default("[]")
  customFields      Json?    @map("custom_fields")
  address           Json?
  source            String?
  
  // Pipeline/Opportunity data
  pipelineId        String?  @map("pipeline_id")
  stageId           String?  @map("stage_id")
  stageName         String?  @map("stage_name")
  opportunityId     String?  @map("opportunity_id")
  opportunityValue  Decimal? @map("opportunity_value") @db.Decimal(12, 2)
  
  // Sync metadata
  lastSyncedAt      DateTime @default(now()) @map("last_synced_at")
  lastEventType     String?  @map("last_event_type") // created, updated, deleted
  syncStatus        String   @default("active") @map("sync_status") // active, merged, deleted
  
  // Raw data cache
  rawData           Json?    @map("raw_data") // Full GHL contact data
  
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  client            Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  appointments      SyncedAppointment[]
  formSubmissions   FormSubmission[]
  emailEvents       EmailEvent[]

  @@index([clientId])
  @@index([ghlContactId])
  @@index([email])
  @@index([syncStatus])
  @@index([clientId, syncStatus])
  @@index([lastSyncedAt])
  @@map("synced_contacts")
}

