  headersEnabled      Boolean   @map("headers_enabled") @default(true)
  retryAfterEnabled   Boolean   @map("retry_after_enabled") @default(true)
  isActive            Boolean   @map("is_active") @default(true)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  clients     Client[]
  apiKeys     ApiKey[]
  usage       RateLimitUsage[]
  violations  RateLimitViolation[]

  @@map("rate_limit_tiers")
}

model RateLimitUsage {
  id              Int       @id @default(autoincrement())
  identifier      String    @db.VarChar(255)
  identifierType  String    @map("identifier_type") @db.VarChar(50)
  tierId          Int?      @map("tier_id")
  windowStart     DateTime  @map("window_start")
  windowEnd       DateTime  @map("window_end")
  requestsCount   Int       @map("requests_count") @default(0)
  tokensRemaining Decimal?  @map("tokens_remaining") @db.Decimal(10, 2)
  lastRefillAt    DateTime? @map("last_refill_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tier RateLimitTier? @relation(fields: [tierId], references: [id], onDelete: SetNull)

  @@unique([identifier, windowStart])
  @@index([identifier, windowStart])
  @@index([windowEnd])
  @@index([tierId])
  @@map("rate_limit_usage")
}

model ApiKey {
  id              String    @id @default(uuid())
  clientId        String?   @map("client_id")
  userId          String?   @map("user_id")
  name            String    @db.VarChar(100)
  keyHash         String    @unique @map("key_hash") @db.VarChar(255)
  keyPrefix       String    @map("key_prefix") @db.VarChar(20)
  tierId          Int?      @map("tier_id")
  customLimits    Json?     @map("custom_limits")
  scopes          Json      @default("[\"read\"]")
  allowedIps      Json?     @map("allowed_ips")
  allowedRoutes   Json?     @map("allowed_routes")
  status          String    @default("active") @db.VarChar(20)
  expiresAt       DateTime? @map("expires_at")
  lastUsedAt      DateTime? @map("last_used_at")
  totalRequests   Int       @map("total_requests") @default(0)
  createdBy       String?   @map("created_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  client        Client?       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user          User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  creator       User?         @relation(name: "ApiKeyCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  tier          RateLimitTier? @relation(fields: [tierId], references: [id], onDelete: SetNull)
  violations    RateLimitViolation[]

  @@index([clientId])
  @@index([keyHash])
  @@index([status])
  @@index([tierId])
  @@map("api_keys")
}

model RateLimitViolation {
  id              Int       @id @default(autoincrement())
  identifier      String    @db.VarChar(255)
  identifierType  String    @map("identifier_type") @db.VarChar(50)
  tierId          Int?      @map("tier_id")
  apiKeyId        String?   @map("api_key_id")
  route           String    @db.VarChar(255)
  method          String    @db.VarChar(10)
  ipAddress       String?   @map("ip_address") @db.Inet
  userAgent       String?   @map("user_agent")
  limitType       String    @map("limit_type") @db.VarChar(50)
  limitValue      Int       @map("limit_value")
  requestsMade    Int       @map("requests_made")
  retryAfter      Int?      @map("retry_after")
  createdAt       DateTime  @default(now()) @map("created_at")

  tier    RateLimitTier? @relation(fields: [tierId], references: [id], onDelete: SetNull)
  apiKey  ApiKey?        @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  @@index([identifier, createdAt])
  @@index([createdAt])
  @@index([tierId])
  @@map("rate_limit_violations")
}

model RateLimitExemption {
  id              Int       @id @default(autoincrement())
  identifier      String    @db.VarChar(255)
  identifierType  String    @map("identifier_type") @db.VarChar(50)
  reason          String
  expiresAt       DateTime? @map("expires_at")
  overrideTierId  Int?      @map("override_tier_id")
  createdBy       String?   @map("created_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@unique([identifier, identifierType])
  @@index([identifier, identifierType])
  @@map("rate_limit_exemptions")
}