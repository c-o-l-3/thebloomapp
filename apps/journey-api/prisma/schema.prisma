  participant ABTestParticipant  @relation(fields: [participantId], references: [id], onDelete: Cascade)
  client      Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([testId])
  @@index([variantId])
  @@index([participantId])
  @@index([eventType])
  @@index([timestamp])
  @@map("ab_test_events")
}

