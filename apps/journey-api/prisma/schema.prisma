// Main A/B Test Configuration
model JourneyABTest {
  id                    String    @id @default(uuid())
  clientId              String    @map("client_id")
  journeyId             String    @map("journey_id")
  name                  String
  description           String?
  hypothesis            String?
  status                String    @default("draft") // draft, running, paused, completed, cancelled
  testType              String    @default("journey") @map("test_type") // journey, touchpoint, subject_line, content
  targetMetric          String    @default("conversion") @map("target_metric") // conversion, click_rate, open_rate, reply_rate
  minConfidenceLevel    Decimal   @default(0.95) @db.Decimal(5,4) @map("min_confidence_level")
  minSampleSize         Int       @default(100) @map("min_sample_size")
  autoWinnerSelection   Boolean   @default(false) @map("auto_winner_selection")
  trafficAllocation     Json      @default("{}") @map("traffic_allocation")
  startDate             DateTime? @map("start_date")
  endDate               DateTime? @map("end_date")
  scheduledStart        DateTime? @map("scheduled_start")
  winnerVariantId       String?   @map("winner_variant_id")
  winnerSelectedAt      DateTime? @map("winner_selected_at")
  winnerSelectionReason String?   @map("winner_selection_reason")
  createdBy             String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  client       Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  journey      Journey               @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  variants     JourneyABTestVariant[]
  participants ABTestParticipant[]
  events       ABTestEvent[]
  dailyStats   ABTestDailyStats[]

  @@unique([clientId, name])
  @@index([clientId])
  @@index([journeyId])
  @@index([status])
  @@index([startDate])
  @@map("journey_ab_tests")
}

// A/B Test Variants
model JourneyABTestVariant {
  id                    String   @id @default(uuid())
  testId                String   @map("test_id")
  clientId              String   @map("client_id")
  journeyId             String   @map("journey_id")
  name                  String   // "Control", "Variant A", etc.
  description           String?
  trafficPercentage     Decimal  @default(50.00) @db.Decimal(5,2) @map("traffic_percentage")
  journeySnapshot       Json     @map("journey_snapshot")
  touchpointChanges     Json?    @map("touchpoint_changes")
  isControl             Boolean  @default(false) @map("is_control")
  status                String   @default("active") // active, disabled, winner, loser
  participantsCount     Int      @default(0) @map("participants_count")
  conversionsCount      Int      @default(0) @map("conversions_count")
  conversionRate        Decimal  @default(0) @db.Decimal(5,4) @map("conversion_rate")
  confidenceLevel       Decimal  @default(0) @db.Decimal(5,4) @map("confidence_level")
  improvementPercentage Decimal  @default(0) @db.Decimal(6,2) @map("improvement_percentage")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  test         JourneyABTest      @relation(fields: [testId], references: [id], onDelete: Cascade)
  client       Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  journey      Journey            @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  participants ABTestParticipant[]
  events       ABTestEvent[]
  dailyStats   ABTestDailyStats[]

  @@index([testId])
  @@index([clientId])
  @@index([status])
  @@map("journey_ab_test_variants")
}

// A/B Test Participants Tracking
model ABTestParticipant {
  id                   String    @id @default(uuid())
  testId               String    @map("test_id")
  variantId            String    @map("variant_id")
  clientId             String    @map("client_id")
  contactId            String    @map("contact_id")
  sessionId            String?
  journeyId            String    @map("journey_id")
  entryTouchpointId    String?   @map("entry_touchpoint_id")
  assignedAt           DateTime  @default(now()) @map("assigned_at")
  convertedAt          DateTime? @map("converted_at")
  conversionValue      Decimal?  @db.Decimal(12,2) @map("conversion_value")
  conversionEvent      String?   @map("conversion_event")
  droppedOffAt         DateTime? @map("dropped_off_at")
  dropOffTouchpointId  String?   @map("drop_off_touchpoint_id")
  timeInJourneyMinutes Int?      @map("time_in_journey_minutes")
  deviceType           String?   @map("device_type")
  utmSource            String?   @map("utm_source")
  utmMedium            String?   @map("utm_medium")
  utmCampaign          String?   @map("utm_campaign")
  metadata             Json      @default("{}")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  test     JourneyABTest      @relation(fields: [testId], references: [id], onDelete: Cascade)
  variant  JourneyABTestVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  client   Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  events   ABTestEvent[]

  @@unique([testId, contactId])
  @@index([testId])
  @@index([variantId])
  @@index([clientId])
  @@index([contactId])
  @@index([convertedAt])
  @@map("ab_test_participants")
}

// A/B Test Events/Conversions
model ABTestEvent {
  id            String   @id @default(uuid())
  testId        String   @map("test_id")
  variantId     String   @map("variant_id")
  participantId String   @map("participant_id")
  clientId      String   @map("client_id")
  eventType     String   @map("event_type")
  eventData     Json     @default("{}") @map("event_data")
  touchpointId  String?  @map("touchpoint_id")
