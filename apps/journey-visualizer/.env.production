# Production Environment Variables for Zeabur Deployment
# These are injected at build time

# Data Source - Use API in production (not local files)
VITE_DATA_SOURCE=api

# API Configuration - Point to production backend
VITE_API_URL=https://bloom-backend.zeabur.app/api
VITE_API_BASE_URL=https://bloom-backend.zeabur.app/api

# App Configuration
VITE_APP_NAME=BloomBuilder Journey Visualizer
VITE_APP_VERSION=1.0.0
