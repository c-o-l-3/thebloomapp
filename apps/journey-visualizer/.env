# Journey Visualizer Environment Variables

# Data Source Configuration
VITE_DATA_SOURCE=api  # Options: api, local

# API Configuration (when VITE_DATA_SOURCE=api)
VITE_API_URL=http://localhost:8080/api

# Client Configuration (for local mode)
# VITE_CLIENT_SLUG=promise-farm

# GoHighLevel Configuration
VITE_GHL_API_KEY=your_gohighlevel_api_key

# Optional: API Endpoints
# VITE_GHL_API_URL=https://api.gohighlevel.com/v2

# Optional: Feature Flags
# VITE_ENABLE_REALTIME_UPDATES=true
# VITE_ENABLE_NOTIFICATIONS=true
