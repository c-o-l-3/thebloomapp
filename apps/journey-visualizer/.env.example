# Journey Visualizer Environment Variables
# Copy this file to .env and fill in your values

# Data Source Configuration
# Options: 'api' (PostgreSQL - recommended), 'local' (development)
VITE_DATA_SOURCE=api

# PostgreSQL API Configuration (New - Recommended)
VITE_API_URL=http://localhost:3001/api

# GoHighLevel Configuration
VITE_GHL_API_KEY=your_gohighlevel_api_key

# Optional: API Endpoints (defaults are set in services)
# VITE_GHL_API_URL=https://api.gohighlevel.com/v2

# Optional: Feature Flags
# VITE_ENABLE_REALTIME_UPDATES=true
# VITE_ENABLE_NOTIFICATIONS=true
